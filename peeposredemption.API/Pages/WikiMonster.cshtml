@page "/wiki/monster/{slug}"
@model peeposredemption.API.Pages.WikiMonsterModel
@using peeposredemption.Domain.Entities
@{
    Layout = "_LandingLayout";
    var m = Model.Monster!;
    var elemName = m.Element == Element.None ? "" : m.Element.ToString();
    ViewData["Title"] = m.Name;
    ViewData["OgTitle"] = $"{m.Name} — Torvex Wiki";
    ViewData["Description"] = $"Level {m.Level} {elemName} monster in {m.Zone}. Stats and drop table.";
}

@section Head {
<style>
.monster-page { max-width: 720px; margin: 0 auto; padding: 40px 24px 80px; }
.monster-page-back { display: inline-flex; align-items: center; gap: 6px; color: var(--text-muted); font-size: 14px; margin-bottom: 32px; transition: color 0.15s; }
.monster-page-back:hover { color: var(--accent); }

.monster-page-header { display: flex; align-items: center; gap: 20px; margin-bottom: 24px; }
.monster-page-icon { font-size: 56px; line-height: 1; flex-shrink: 0; }
.monster-page-title h1 { font-size: clamp(20px,4vw,32px); font-weight: 800; color: var(--text-primary); margin-bottom: 8px; }
.badges { display: flex; gap: 6px; flex-wrap: wrap; }
.badge { font-size: 12px; font-weight: 600; padding: 3px 10px; border-radius: 12px; background: rgba(255,255,255,0.07); color: var(--text-secondary); }

.stat-row { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }
.stat-pill { font-size: 13px; padding: 5px 11px; border-radius: 8px; background: rgba(255,255,255,0.06); color: var(--text-secondary); }
.stat-pill.dmg { background: rgba(255,100,100,0.15); color: #ff9999; }
.stat-pill.xp  { background: rgba(59,165,92,0.15);   color: #3ba55c; }

.ability-chip { font-size: 12px; padding: 3px 9px; border-radius: 7px; background: rgba(255,100,100,0.12); color: #ff9999; font-weight: 600; }
.abilities-row { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 24px; }

.section-box { background: var(--bg-card); border-radius: 12px; padding: 20px; border: 1px solid rgba(255,255,255,0.06); }
.section-label { font-size: 12px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 14px; }

.drop-table { width: 100%; border-collapse: collapse; font-size: 14px; }
.drop-table td { padding: 9px 6px; border-bottom: 1px solid rgba(255,255,255,0.05); color: var(--text-secondary); vertical-align: middle; }
.drop-table tr:last-child td { border-bottom: none; }
.drop-table a { color: var(--accent); text-decoration: none; }
.drop-table a:hover { text-decoration: underline; }
.drop-chance { font-size: 12px; font-weight: 700; padding: 2px 8px; border-radius: 6px; white-space: nowrap; }
.chance-high   { background: rgba(59,165,92,0.2);  color: #3ba55c; }
.chance-medium { background: rgba(255,165,0,0.2);  color: #ffa500; }
.chance-low    { background: rgba(255,80,80,0.2);  color: #ff6464; }

.elem-Fire{color:#ff7043}.elem-Ice{color:#81d4fa}.elem-Lightning{color:#ffd54f}.elem-Earth{color:#a5d6a7}
.elem-Water{color:#4fc3f7}.elem-Wind{color:#e0e0e0}.elem-Holy{color:#fff59d}.elem-Dark{color:#ce93d8}
.elem-Light{color:#fff9c4}.elem-Shadow{color:#b39ddb}.elem-Poison{color:#aed581}.elem-Void{color:#90a4ae}
</style>
}

<div class="monster-page">
    <a href="/wiki#monsters" class="monster-page-back">← Back to Wiki</a>

    <div class="monster-page-header">
        <div class="monster-page-icon">@m.Icon</div>
        <div class="monster-page-title">
            <h1>@m.Name</h1>
            <div class="badges">
                <span class="badge">Lv.@m.Level</span>
                <span class="badge">@m.Zone</span>
                @if (!string.IsNullOrEmpty(elemName))
                {
                    <span class="badge elem-@elemName">@elemName</span>
                }
            </div>
        </div>
    </div>

    <div class="stat-row">
        <span class="stat-pill">❤️ @m.MaxHp HP</span>
        <span class="stat-pill dmg">⚔️ @m.MinDamage–@m.MaxDamage</span>
        <span class="stat-pill">🛡️ @m.DEF DEF</span>
        <span class="stat-pill">💪 @m.STR STR</span>
        <span class="stat-pill">🔮 @m.INT INT</span>
        <span class="stat-pill">🎯 @m.DEX DEX</span>
        <span class="stat-pill xp">✨ @m.XpReward XP</span>
        <span class="stat-pill">🔮 @m.OrbMin–@m.OrbMax orbs</span>
    </div>

    @if (m.Abilities.Any())
    {
        <div class="abilities-row">
            @foreach (var ability in m.Abilities)
            {
                <span class="ability-chip">@ability</span>
            }
        </div>
    }

    <div class="section-box">
        <div class="section-label">Drop Table</div>
        @if (m.Loot.Any())
        {
            <table class="drop-table">
                @foreach (var drop in m.Loot)
                {
                    var chanceClass = drop.DropChance >= 50 ? "chance-high" : drop.DropChance >= 20 ? "chance-medium" : "chance-low";
                    var qty = drop.MaxQty > 1 ? $" ×{drop.MinQty}–{drop.MaxQty}" : "";
                    <tr>
                        <td style="font-size:20px;width:32px">@drop.ItemIcon</td>
                        <td><a href="/wiki/item/@drop.ItemSlug">@drop.ItemName</a></td>
                        <td style="text-align:right"><span class="drop-chance @chanceClass">@drop.DropChance%@qty</span></td>
                    </tr>
                }
            </table>
        }
        else
        {
            <p style="color:var(--text-muted);font-size:14px;margin:0">No recorded drops.</p>
        }
    </div>
</div>
