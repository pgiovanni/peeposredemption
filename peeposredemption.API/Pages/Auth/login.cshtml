@page
@model peeposredemption.API.Pages.Auth.LoginModel
<h2>Login</h2>
<form method="post">
    <input asp-for="Input.Email" type="email" placeholder="Email" />
    <span asp-validation-for="Input.Email"></span>
    <input asp-for="Input.Password" type="password" placeholder="Password" />
    <span asp-validation-for="Input.Password"></span>
    <div asp-validation-summary="All"></div>
    <button type="submit">Login</button>
    <a href="/Auth/Register">Register</a>
</form>
<p>Didn't receive a confirmation email? <a href="/Auth/ResendConfirmation">Click here to resend it</a></p>
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
