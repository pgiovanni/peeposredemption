@page
@model peeposredemption.API.Pages.Auth.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<script>document.body.classList.add('auth-page');</script>

<div class="auth-container">
    <div style="text-align: center; margin-bottom: 8px;">
        <img src="/images/orb.png" alt="Orb" style="width: 64px; height: 64px;" />
    </div>
    <h1>Reset Password</h1>

    @if (Model.TokenValid)
    {
        @if (Model.Success)
        {
            <div class="form-success" style="margin-bottom: 16px;">
                Password changed successfully! You can now log in with your new password.
            </div>
            <a href="/Auth/Login" class="btn-primary" style="display: block; text-align: center; margin-top: 12px;">
                Go to Login
            </a>
        }
        else
        {
            <form method="post">
                <input type="hidden" name="token" value="@Model.Token" />

                @if (Model.ErrorMessage != null)
                {
                    <div class="form-error" style="margin-bottom: 12px;">@Model.ErrorMessage</div>
                }

                <div class="form-group">
                    <label>New Password</label>
                    <input type="password" name="newPassword" placeholder="Enter new password" required minlength="6" />
                </div>

                <div class="form-group">
                    <label>Confirm Password</label>
                    <input type="password" name="confirmPassword" placeholder="Confirm new password" required minlength="6" />
                </div>

                <button type="submit" class="btn-primary" style="width: 100%; margin-top: 8px;">Reset Password</button>
            </form>
        }
    }
    else
    {
        <div class="form-error" style="margin-bottom: 16px;">
            This reset link is invalid or has expired. Please request a new one from your profile settings.
        </div>
        <a href="/Auth/Login" class="btn-primary" style="display: block; text-align: center; margin-top: 12px;">
            Go to Login
        </a>
    }
</div>
