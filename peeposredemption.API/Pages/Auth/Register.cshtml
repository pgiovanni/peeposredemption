@page
@model peeposredemption.API.Pages.Auth.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<script>document.body.classList.add('auth-page');</script>

<div class="auth-container">
    <div style="text-align: center; margin-bottom: 8px;">
        <img src="/images/orb.png" alt="Orb" style="width: 64px; height: 64px;" />
    </div>
    <h1>Create Account</h1>

    <form method="post">
        <div asp-validation-summary="All" class="text-danger" style="margin-bottom: 12px; font-size: 13px;"></div>

        <div class="form-group">
            <label>Username</label>
            <input asp-for="Input.Username" placeholder="Username" />
        </div>

        <div class="form-group">
            <label>Email</label>
            <input asp-for="Input.Email" type="email" placeholder="Email" />
        </div>

        <div class="form-group">
            <label>Password</label>
            <input asp-for="Input.Password" type="password" placeholder="Password" />
        </div>

        <div class="form-group">
            <label>Confirm Password</label>
            <input asp-for="ConfirmPassword" type="password" placeholder="Confirm Password" />
        </div>

        <div class="form-group">
            <label>Date of Birth</label>
            <input asp-for="Input.DateOfBirth" type="date" />
        </div>

        <input type="hidden" asp-for="RefCode" />
        <input type="hidden" asp-for="InviteCode" />

        <div class="cf-turnstile" data-sitekey="@ViewData["TurnstileSiteKey"]" style="margin-top: 12px;"></div>

        <button type="submit" class="btn-primary" style="width: 100%; margin-top: 8px;">Register</button>
    </form>

    <p style="text-align: center; margin-top: 16px; font-size: 13px; color: #949ba4;">
        Already have an account? <a href="/Auth/Login" style="color: #5865f2;">Log in</a>
    </p>
    <p style="text-align: center; margin-top: 8px; font-size: 11px; color: #4e5058;">
        By registering, you agree to our <a href="/Privacy" style="color: #4e5058; text-decoration: underline;">Privacy Policy</a>
        &nbsp;&middot;&nbsp;
        <a href="/TrustSafety" style="color: #4e5058; text-decoration: underline;">Trust & Safety</a>
    </p>
</div>

@section Scripts {
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        // Track referral link click
        (function() {
            var params = new URLSearchParams(window.location.search);
            var ref = params.get('ref');
            if (ref) {
                fetch('/api/referral/track-click', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ code: ref })
                }).catch(function() {});
            }
        })();
    </script>
}
