@using peeposredemption.Application.DTOs.Servers
@model peeposredemption.API.Pages.App.ServerListViewModel

<div id="server-list">
    <a href="/App/Index" class="server-icon home-icon" title="Direct Messages">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20 2H4a2 2 0 0 0-2 2v18l4-4h14a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2z"/>
        </svg>
        @if (Model.UnreadCount > 0)
        {
            <span class="notif-badge">@(Model.UnreadCount > 9 ? "9+" : Model.UnreadCount.ToString())</span>
        }
    </a>
    <div id="dm-indicators"></div>
    <div class="server-separator"></div>

    @foreach (var server in Model.Servers)
    {
        var channelId = Model.ServerDefaultChannels.GetValueOrDefault(server.Id);
        var serverUnread = Model.ServerUnreadCounts.GetValueOrDefault(server.Id, 0);
        <a href="/App/Channel?channelId=@channelId&serverId=@server.Id"
           class="server-icon @(Model.ActiveServerId == server.Id ? "active" : "")"
           title="@server.Name"
           data-server-id="@server.Id">
            @if (server.IconUrl != null)
            {
                <img src="@server.IconUrl" alt="@server.Name" />
            }
            else
            {
                <span>@server.Name.Substring(0, 1).ToUpper()</span>
            }
            @if (serverUnread > 0)
            {
                <span class="notif-badge">@(serverUnread > 9 ? "9+" : serverUnread.ToString())</span>
            }
        </a>
    }

    <a href="/App/Referral" class="server-icon" title="Referral Program" style="font-size:1.1rem">💰</a>

    @{
        var config = Context.RequestServices.GetRequiredService<Microsoft.Extensions.Configuration.IConfiguration>();
        var adminEmail = config["Email:AdminEmail"] ?? "";
        var userEmail = Context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
        if (!string.IsNullOrEmpty(adminEmail) && string.Equals(userEmail, adminEmail, StringComparison.OrdinalIgnoreCase))
        {
            <a href="/App/Admin/SecurityAdmin" class="server-icon" title="Security Admin" style="font-size:1.1rem">🛡️</a>
        }
    }

    <a href="/App/Profile" class="server-icon profile-link" title="Edit Profile">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
        </svg>
    </a>

    <a href="/Privacy" class="server-icon" title="Privacy Policy" style="font-size:1.1rem">📜</a>

    <button class="server-icon add-server" id="open-create-server" title="Create a Server">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/>
        </svg>
    </button>
</div>

<!-- Create Server Modal -->
<div id="create-server-modal" class="modal hidden">
    <div class="modal-backdrop" id="modal-backdrop"></div>
    <div class="modal-content">
        <h2>Create a Server</h2>
        <p class="modal-subtitle">Give your server a name. You can always change it later.</p>
        <form method="post" asp-page="/App/Index" asp-page-handler="CreateServer">
            <input type="text" name="Name" placeholder="My Awesome Server" required maxlength="100" />
            <div class="modal-actions">
                <button type="button" class="btn-cancel" id="close-create-server">Cancel</button>
                <button type="submit" class="btn-primary">Create Server</button>
            </div>
        </form>
    </div>
</div>

<script>
    document.getElementById('open-create-server').addEventListener('click', () => {
        document.getElementById('create-server-modal').classList.remove('hidden');
    });
    document.getElementById('close-create-server').addEventListener('click', () => {
        document.getElementById('create-server-modal').classList.add('hidden');
    });
    document.getElementById('modal-backdrop').addEventListener('click', () => {
        document.getElementById('create-server-modal').classList.add('hidden');
    });
</script>
