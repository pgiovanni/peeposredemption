@using peeposredemption.Application.DTOs.Servers
@model peeposredemption.API.Pages.App.ServerListViewModel

<div id="server-list">
    <a href="/App/Index" class="server-icon home-icon" title="Direct Messages">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20 2H4a2 2 0 0 0-2 2v18l4-4h14a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2z"/>
        </svg>
        @if (Model.UnreadCount > 0)
        {
            <span class="notif-badge">@(Model.UnreadCount > 9 ? "9+" : Model.UnreadCount.ToString())</span>
        }
    </a>
    <div id="dm-indicators"></div>
    <div class="server-separator"></div>

    @foreach (var server in Model.Servers)
    {
        var channelId = Model.ServerDefaultChannels.GetValueOrDefault(server.Id);
        var serverUnread = Model.ServerUnreadCounts.GetValueOrDefault(server.Id, 0);
        <a href="/App/Channel?channelId=@channelId&serverId=@server.Id"
           class="server-icon @(Model.ActiveServerId == server.Id ? "active" : "") @(server.IsPersonal ? "personal-server" : "")"
           title="@server.Name"
           data-server-id="@server.Id"
           @(server.IsPersonal ? "data-personal=\"true\"" : "draggable=\"true\"")>
            @if (server.IconUrl != null)
            {
                <img src="@server.IconUrl" alt="@server.Name" />
            }
            else
            {
                <span>@server.Name.Substring(0, 1).ToUpper()</span>
            }
            @if (serverUnread > 0)
            {
                <span class="notif-badge">@(serverUnread > 9 ? "9+" : serverUnread.ToString())</span>
            }
        </a>
    }

    <div id="personal-server-tip" class="personal-server-tip hidden">
        <span>This is your server — invite your friends!</span>
        <button id="dismiss-personal-tip" aria-label="Dismiss">&times;</button>
    </div>

    <a href="/App/Referral" class="server-icon" title="Referral Program" style="font-size:1.1rem">💰</a>

    <button class="server-icon add-server" id="open-create-server" title="Create a Server">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/>
        </svg>
    </button>

    <a href="/Privacy" class="server-icon" title="Privacy Policy" style="font-size:0.9rem;margin-top:auto">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
        </svg>
    </a>
</div>

<!-- Switch Accounts Panel -->
<div id="switch-accounts-overlay" class="switch-accounts-overlay hidden"></div>
<div id="switch-accounts-panel" class="switch-accounts-panel">
    <div class="switch-accounts-header">
        <span>Accounts on this device</span>
        <button id="close-switch-accounts" class="switch-accounts-close" aria-label="Close">&times;</button>
    </div>
    <div id="switch-accounts-list"></div>
    <div class="switch-accounts-divider"></div>
    <form method="post" action="/Auth/Logout" id="switch-logout-form" style="display:none">
        @Html.AntiForgeryToken()
    </form>
    <button class="switch-accounts-add" id="switch-accounts-add-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/>
        </svg>
        Add Account
    </button>
</div>

<!-- Create Server Modal -->
<div id="create-server-modal" class="modal hidden">
    <div class="modal-backdrop" id="modal-backdrop"></div>
    <div class="modal-content">
        <h2>Create a Server</h2>
        <p class="modal-subtitle">Give your server a name. You can always change it later.</p>
        <form method="post" asp-page="/App/Index" asp-page-handler="CreateServer">
            <input type="text" name="Name" placeholder="My Awesome Server" required maxlength="100" />
            <div class="modal-actions">
                <button type="button" class="btn-cancel" id="close-create-server">Cancel</button>
                <button type="submit" class="btn-primary">Create Server</button>
            </div>
        </form>
    </div>
</div>

<script>
    document.getElementById('open-create-server').addEventListener('click', () => {
        document.getElementById('create-server-modal').classList.remove('hidden');
    });
    document.getElementById('close-create-server').addEventListener('click', () => {
        document.getElementById('create-server-modal').classList.add('hidden');
    });
    document.getElementById('modal-backdrop').addEventListener('click', () => {
        document.getElementById('create-server-modal').classList.add('hidden');
    });

    // ── Personal server invite tip ───────────────────────────────────
    (function () {
        const personalIcon = document.querySelector('#server-list a.server-icon[data-personal="true"]');
        const tip = document.getElementById('personal-server-tip');
        const dismiss = document.getElementById('dismiss-personal-tip');

        if (personalIcon && tip && !localStorage.getItem('personalTipDismissed')) {
            // Position tip next to the personal server icon
            function positionTip() {
                const rect = personalIcon.getBoundingClientRect();
                tip.style.top = (rect.top + rect.height / 2) + 'px';
            }
            positionTip();
            tip.classList.remove('hidden');
        }

        dismiss?.addEventListener('click', () => {
            tip.classList.add('hidden');
            localStorage.setItem('personalTipDismissed', '1');
        });
    })();

    // ── Server Drag-and-Drop Reordering ─────────────────────────────
    (function () {
        let dragSrc = null;

        function getServerIcons() {
            // Exclude personal server from drag ordering
            return Array.from(document.querySelectorAll('#server-list a.server-icon[data-server-id]:not([data-personal])'));
        }

        function bindDrag(el) {
            el.addEventListener('dragstart', e => {
                dragSrc = el;
                e.dataTransfer.effectAllowed = 'move';
                e.dataTransfer.setData('text/plain', el.dataset.serverId);
                setTimeout(() => el.classList.add('dragging'), 0);
            });
            el.addEventListener('dragend', () => {
                el.classList.remove('dragging');
                document.querySelectorAll('#server-list a.server-icon').forEach(i => i.classList.remove('drag-over'));
                dragSrc = null;
            });
            el.addEventListener('dragover', e => {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
                if (dragSrc && dragSrc !== el) {
                    document.querySelectorAll('#server-list a.server-icon').forEach(i => i.classList.remove('drag-over'));
                    el.classList.add('drag-over');
                }
            });
            el.addEventListener('dragleave', () => el.classList.remove('drag-over'));
            el.addEventListener('drop', e => {
                e.preventDefault();
                el.classList.remove('drag-over');
                if (!dragSrc || dragSrc === el) return;

                // Reorder in DOM
                const icons = getServerIcons();
                const srcIdx = icons.indexOf(dragSrc);
                const dstIdx = icons.indexOf(el);
                if (srcIdx < dstIdx) {
                    el.after(dragSrc);
                } else {
                    el.before(dragSrc);
                }

                // Persist new order (personal server excluded — always first server-side)
                const newOrder = getServerIcons().map(i => i.dataset.serverId);
                const jwt = document.querySelector('meta[name="jwt"]')?.content;
                fetch('/api/servers/reorder', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + jwt },
                    body: JSON.stringify({ serverIds: newOrder })
                });
            });
        }

        getServerIcons().forEach(bindDrag);
    })();

    // ── Switch Accounts Panel ────────────────────────────────────────
    (function () {
        const STORE_KEY = 'torvex_accounts';
        const panel     = document.getElementById('switch-accounts-panel');
        const overlay   = document.getElementById('switch-accounts-overlay');
        const list      = document.getElementById('switch-accounts-list');

        // ── Helpers ──────────────────────────────────────────────────
        function getAccounts() {
            try { return JSON.parse(localStorage.getItem(STORE_KEY) || '[]'); } catch { return []; }
        }
        function saveAccounts(accounts) {
            localStorage.setItem(STORE_KEY, JSON.stringify(accounts));
        }
        function decodeJwtPayload(token) {
            try {
                const b64 = token.split('.')[1].replace(/-/g,'+').replace(/_/g,'/');
                return JSON.parse(atob(b64));
            } catch { return null; }
        }

        // ── Save current session into the store on every page load ───
        const currentJwt = document.querySelector('meta[name="jwt"]')?.content;
        if (currentJwt) {
            const payload = decodeJwtPayload(currentJwt);
            const userId  = payload?.['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier'];
            const username = payload?.['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name'];
            if (userId && username) {
                const accounts = getAccounts().filter(a => a.userId !== userId);
                accounts.unshift({ userId, username, jwt: currentJwt, active: true });
                saveAccounts(accounts);
            }
        }

        // ── Render account list ──────────────────────────────────────
        function renderAccounts() {
            const accounts = getAccounts();
            const currentPayload = currentJwt ? decodeJwtPayload(currentJwt) : null;
            const currentUserId  = currentPayload?.['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier'];
            list.innerHTML = '';
            accounts.forEach(acc => {
                const isActive = acc.userId === currentUserId;
                const row = document.createElement('div');
                row.className = 'switch-accounts-current' + (isActive ? '' : ' switch-accounts-inactive');
                row.innerHTML = `
                    <div class="switch-accounts-avatar">${acc.username[0].toUpperCase()}</div>
                    <div class="switch-accounts-info" style="flex:1;min-width:0">
                        <span class="switch-accounts-name">${acc.username}</span>
                        <span class="switch-accounts-badge">${isActive ? 'Active' : 'Saved'}</span>
                    </div>
                    ${isActive
                        ? `<button class="switch-accounts-logout-btn" data-logout-active>Log Out</button>`
                        : `<button class="switch-accounts-logout-btn switch-btn" data-switch-jwt="${encodeURIComponent(acc.jwt)}" data-user-id="${acc.userId}">Switch</button>
                           <button class="switch-accounts-remove-btn" data-remove-id="${acc.userId}" title="Remove">×</button>`
                    }`;
                list.appendChild(row);
            });
        }

        // ── Panel open/close ─────────────────────────────────────────
        function openPanel() {
            renderAccounts();
            overlay.classList.remove('hidden');
            panel.classList.add('open');
        }
        function closePanel() {
            panel.classList.remove('open');
            overlay.classList.add('hidden');
        }

        document.addEventListener('click', e => {
            if (e.target.closest('[data-switch-accounts]')) { e.preventDefault(); openPanel(); return; }

            // Log out active account
            if (e.target.closest('[data-logout-active]')) {
                document.getElementById('switch-logout-form').submit();
                return;
            }

            // Switch to inactive account
            const switchBtn = e.target.closest('[data-switch-jwt]');
            if (switchBtn) {
                const jwt = decodeURIComponent(switchBtn.dataset.switchJwt);
                switchBtn.textContent = '...';
                switchBtn.disabled = true;
                fetch('/api/auth/switch', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ jwt })
                }).then(r => {
                    if (r.ok) { window.location.href = '/App/Index'; }
                    else {
                        // Token too old / user deleted — remove from store
                        const uid = switchBtn.dataset.userId;
                        saveAccounts(getAccounts().filter(a => a.userId !== uid));
                        renderAccounts();
                    }
                }).catch(() => { switchBtn.textContent = 'Switch'; switchBtn.disabled = false; });
                return;
            }

            // Remove saved account from store (no server call needed)
            const removeBtn = e.target.closest('[data-remove-id]');
            if (removeBtn) {
                const uid = removeBtn.dataset.removeId;
                saveAccounts(getAccounts().filter(a => a.userId !== uid));
                renderAccounts();
                return;
            }
        });

        document.getElementById('close-switch-accounts')?.addEventListener('click', closePanel);
        overlay?.addEventListener('click', closePanel);

        // "Add Account" — navigate to login without revoking anything
        document.getElementById('switch-accounts-add-btn')?.addEventListener('click', () => {
            window.location.href = '/Auth/Login?addAccount=true';
        });
    })();
</script>
