<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="MvoHAl7vXmYuZPAwD7xSZMY_WK8rYii2s9pygJ7UvGg" />
    <title>@ViewData["Title"] - Torvex</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/game.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <meta name="jwt" content="@(Context.Items["CurrentJwt"] as string ?? Context.Request.Cookies["jwt"])" />
    <meta name="gif-key" content="@(Microsoft.Extensions.DependencyInjection.ServiceProviderServiceExtensions.GetRequiredService<Microsoft.Extensions.Configuration.IConfiguration>(Context.RequestServices)["Klipy:ApiKey"])" />

    @{
        var seoDescription = ViewData["Description"]?.ToString()
            ?? "Torvex — a free community platform with real-time chat, voice channels, a built-in RPG, and an orbs economy.";
        var seoTitle = ViewData["Title"]?.ToString() ?? "Torvex";
        var seoUrl = $"https://{Context.Request.Host}{Context.Request.Path}";
        var seoImage = "https://torvex.app/images/og-preview.png";
    }
    <meta name="description" content="@seoDescription" />
    @if (ViewData["NoIndex"] is true) {
        <meta name="robots" content="noindex, nofollow" />
    }
    <link rel="canonical" href="@seoUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Torvex" />
    <meta property="og:title" content="@seoTitle" />
    <meta property="og:description" content="@seoDescription" />
    <meta property="og:image" content="@seoImage" />
    <meta property="og:url" content="@seoUrl" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@seoTitle" />
    <meta name="twitter:description" content="@seoDescription" />
    <meta name="twitter:image" content="@seoImage" />
    <script defer src="https://admin.torvex.app/script.js" data-website-id="792c9bad-5274-4e2e-ac7d-227e16d08e71"></script>
</head>
<body>
    @RenderBody()
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@twemoji/api@@latest/dist/twemoji.min.js" crossorigin="anonymous"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const shell = document.querySelector('.app-shell');
            if (!shell) return;

            const menuBtn = shell.querySelector('.mobile-menu-btn');
            const backdrop = shell.querySelector('.sidebar-backdrop');

            if (menuBtn) {
                menuBtn.addEventListener('click', () => shell.classList.toggle('sidebar-open'));
            }
            if (backdrop) {
                backdrop.addEventListener('click', () => shell.classList.remove('sidebar-open'));
            }

            // Close sidebar when navigating (clicking a channel/server/friend)
            shell.querySelectorAll('.channel-item, .dm-item, .server-icon').forEach(el => {
                el.addEventListener('click', () => shell.classList.remove('sidebar-open'));
            });

            // Swipe to close sidebar
            let touchStartX = 0;
            document.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
            document.addEventListener('touchend', e => {
                const dx = e.changedTouches[0].clientX - touchStartX;
                if (dx < -60 && shell.classList.contains('sidebar-open')) {
                    shell.classList.remove('sidebar-open');
                }
                if (dx > 50 && touchStartX < window.innerWidth * 0.4 && !shell.classList.contains('sidebar-open')) {
                    shell.classList.add('sidebar-open');
                }
            }, { passive: true });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    @{
        var uidClaim = Context.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (uidClaim != null)
        {
            var uow = Context.RequestServices.GetRequiredService<peeposredemption.Domain.Interfaces.IUnitOfWork>();
            var currentUser = await uow.Users.GetByIdAsync(Guid.Parse(uidClaim));
            if (currentUser?.IsSuspicious == true)
            {
                <script src="~/js/fingerprint.js" asp-append-version="true"></script>
            }
        }
    }
</body>
</html>
