<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"] - peeposredemption</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <meta name="jwt" content="@Context.Request.Cookies["jwt"]" />
</head>
<body>
    <div class="app-shell">
        <nav class="server-sidebar">
            @foreach (var server in ViewBag.Servers ?? new List<dynamic>())
            {
                <a href="/App/Index?serverId=@server.Id">@server.Name</a>
            }
        </nav>
        <main>@RenderBody()</main>
    </div>
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
