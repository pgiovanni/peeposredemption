@page
@model peeposredemption.API.Pages.App.ChannelModel
@{
    ViewData["Title"] = Model.ChannelName;
}

<div class="app-shell">

    <!-- Col 1: Server icon strip -->
    <partial name="_ServerList" model="Model.ServerList" />

    <!-- Col 2: Channel list -->
    <div class="sidebar">
        <div class="sidebar-header server-name-header">
            <span>@Model.ServerName</span>
            @if (Model.CurrentUserRole == peeposredemption.Domain.Entities.ServerRole.Owner)
            {
                <a href="/App/ServerSettings?serverId=@Model.ServerId" class="icon-btn" title="Server Settings">⚙</a>
            }
        </div>

        @if (Model.InviteLink != null)
        {
            <div class="invite-section" id="invite-section">
                <span class="invite-label">Invite</span>
                <a href="@Model.InviteLink" class="invite-link" title="@Model.InviteLink">Copy Link</a>
            </div>
        }

        <div class="sidebar-section-header">
            CHANNELS
            <button class="icon-btn" id="add-channel-toggle" title="Create Channel">+</button>
        </div>
        <div id="add-channel-section" class="hidden">
            <form method="post" asp-page-handler="CreateChannel" class="add-friend-form">
                <input type="hidden" name="serverId" value="@Model.ServerId" />
                <div style="display:flex;gap:6px;align-items:center;margin-bottom:4px">
                    <input type="text" name="name" placeholder="new-channel" required maxlength="100" autocomplete="off" style="flex:1" />
                    <select name="channelType" class="channel-type-select">
                        <option value="0">Text</option>
                        <option value="1">Voice</option>
                    </select>
                </div>
                <button type="submit" class="btn-primary btn-sm">Create</button>
            </form>
        </div>
        @foreach (var ch in Model.Channels)
        {
            <div class="channel-row">
                <a href="/App/Channel?channelId=@ch.Id&serverId=@Model.ServerId"
                   class="channel-item @(ch.Id == Model.ChannelId ? "active" : "")"
                   data-channel-id="@ch.Id"
                   data-channel-type="@ch.Type"
                   data-channel-name="@ch.Name">
                    @if (ch.Type == 1)
                    {
                        <span class="channel-hash" title="Voice Channel">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle">
                                <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
                            </svg>
                        </span>
                    }
                    else
                    {
                        <span class="channel-hash">#</span>
                    }
                    <span>@ch.Name</span>
                </a>
                @if (Model.CurrentUserRole >= peeposredemption.Domain.Entities.ServerRole.Moderator)
                {
                    <a href="/App/ChannelSettings?channelId=@ch.Id&serverId=@Model.ServerId" class="icon-btn channel-gear-btn" title="Channel Settings">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.49.49 0 0 0-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.48.48 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96a.49.49 0 0 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6A3.6 3.6 0 1 1 12 8.4a3.6 3.6 0 0 1 0 7.2z"/>
                        </svg>
                    </a>
                }
            </div>
            @if (ch.Type == 1)
            {
                <div class="voice-sidebar-participants" data-voice-channel="@ch.Id">
                    @if (Model.InitialVoiceParticipants.TryGetValue(ch.Id, out var initParts))
                    {
                        @foreach (var p in initParts)
                        {
                            <div class="voice-sidebar-user">
                                @if (!string.IsNullOrEmpty(p.AvatarUrl))
                                {
                                    <img src="@p.AvatarUrl" class="voice-sidebar-avatar" alt="" />
                                }
                                else
                                {
                                    <div class="voice-sidebar-avatar voice-sidebar-avatar-fallback">@p.DisplayName[0].ToString().ToUpper()</div>
                                }
                                <span>@p.DisplayName</span>
                            </div>
                        }
                    }
                </div>
            }
        }
        <div id="voice-bar" class="voice-bar hidden">
            <div class="voice-bar-info">
                <span class="voice-bar-dot"></span>
                <div>
                    <div class="voice-bar-status">Voice Connected</div>
                    <div id="voice-bar-name" class="voice-bar-channel"></div>
                </div>
            </div>
            <div class="voice-bar-btns">
                <a id="voice-bar-return" href="#" class="voice-bar-btn" title="Return to voice">&#x21A9;</a>
                <button id="voice-bar-leave" class="voice-bar-btn voice-bar-leave-btn" title="Disconnect">&#x2715;</button>
            </div>
        </div>

        <div class="sidebar-footer">
            <a href="/App/Profile" title="Edit Profile">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </svg>
                Profile
            </a>
        </div>
    </div>

    <div class="sidebar-backdrop"></div>

    <!-- Col 3: Content -->
    <div class="content-area">
        <div class="content-header">
            <button class="mobile-menu-btn" aria-label="Open menu">&#9776;</button>
            @if (Model.ChannelType == 1)
            {
                <span class="channel-hash">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle">
                        <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
                    </svg>
                </span>
            }
            else
            {
                <span class="channel-hash">#</span>
            }
            <span>@Model.ChannelName</span>
            <a href="/App/Wallet" class="orb-balance" title="View Wallet" style="margin-left:auto">
                <span class="orb-icon"></span>
                <span id="orb-count">@Model.OrbBalance</span>
            </a>
            <button id="notif-mute-toggle" class="icon-btn" title="Toggle notification sound">🔔</button>
            <partial name="_NotifDropdown" />
            @{
                var config = HttpContext.RequestServices.GetRequiredService<Microsoft.Extensions.Configuration.IConfiguration>();
                var adminEmail = config["Email:AdminEmail"] ?? "";
                var userEmail = HttpContext.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
                if (!string.IsNullOrEmpty(adminEmail) && string.Equals(userEmail, adminEmail, StringComparison.OrdinalIgnoreCase))
                {
                    <a href="/App/Admin/SecurityAdmin" class="icon-btn" title="Site Admin" style="font-size:1rem;text-decoration:none">🛡️</a>
                }
            }
        </div>

        @if (Model.ChannelType == 1)
        {
            <!-- Voice Room -->
            <div class="voice-room" id="voice-room">
                <div class="voice-grid" id="voice-grid">
                    <!-- Video tiles injected by voice.js -->
                </div>
                <div class="voice-controls" id="voice-controls">
                    <button class="vc-btn" id="vc-mute" title="Mute">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.91-3c-.49 0-.9.36-.98.85C16.52 14.2 14.47 16 12 16s-4.52-1.8-4.93-4.15c-.08-.49-.49-.85-.98-.85-.61 0-1.09.54-1 1.14.49 3 2.89 5.35 5.91 5.78V20c0 .55.45 1 1 1s1-.45 1-1v-2.08c3.02-.43 5.42-2.78 5.91-5.78.1-.6-.39-1.14-1-1.14z"/>
                        </svg>
                    </button>
                    <button class="vc-btn" id="vc-deafen" title="Deafen">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 1c-4.97 0-9 4.03-9 9v7c0 1.66 1.34 3 3 3h3v-8H5v-2c0-3.87 3.13-7 7-7s7 3.13 7 7v2h-4v8h3c1.66 0 3-1.34 3-3v-7c0-4.97-4.03-9-9-9z"/>
                        </svg>
                    </button>
                    <button class="vc-btn" id="vc-camera" title="Camera">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z"/>
                        </svg>
                    </button>
                    <button class="vc-btn" id="vc-screen" title="Share Screen">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M20 18c1.1 0 1.99-.9 1.99-2L22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2H0v2h24v-2h-4zM4 6h16v10H4V6z"/>
                        </svg>
                    </button>
                    <button class="vc-btn vc-btn-danger" id="vc-disconnect" title="Disconnect">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 9c-1.6 0-3.15.25-4.6.72v3.1c0 .39-.23.74-.56.9-.98.49-1.87 1.12-2.66 1.85-.18.18-.43.28-.7.28-.28 0-.53-.11-.71-.29L.29 13.08c-.18-.17-.29-.42-.29-.7 0-.28.11-.53.29-.71C3.34 8.78 7.46 7 12 7s8.66 1.78 11.71 4.67c.18.18.29.43.29.71 0 .28-.11.53-.29.71l-2.48 2.48c-.18.18-.43.29-.71.29-.27 0-.52-.11-.7-.28-.79-.74-1.69-1.36-2.67-1.85-.33-.16-.56-.5-.56-.9v-3.1C15.15 9.25 13.6 9 12 9z"/>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Text channel view shown when AJAX-switching away from voice to browse text channels -->
            <div id="text-channel-view" class="hidden">
                <div id="messages" class="messages-container"></div>
                <div id="typing-indicator" class="typing-indicator"></div>
                <div class="message-input-area">
                    <form id="message-form">
                        <input id="message-input" type="text" placeholder="" autocomplete="off" />
                        <button type="submit">Send</button>
                    </form>
                </div>
            </div>
        }
        else
        {
            @if (Model.WelcomeBannerUrl != null)
            {
                <div class="welcome-invite-banner" id="welcome-invite-banner">
                    <button class="welcome-banner-dismiss" id="invite-dismiss" title="Dismiss">&#x2715;</button>
                    <div class="welcome-invite-banner-text">
                        <strong>Invite your friends!</strong>
                        <span>Share your link — when friends sign up through it, you earn referral credit.</span>
                    </div>
                    <div class="welcome-invite-banner-link">
                        <input class="welcome-invite-banner-input" value="@Model.WelcomeBannerUrl" readonly />
                        <button class="btn-primary btn-sm" onclick="navigator.clipboard.writeText('@Model.WelcomeBannerUrl');this.textContent='Copied!';setTimeout(()=>this.textContent='Copy',2000)">Copy</button>
                    </div>
                </div>
            }
            <!-- Text Channel Messages -->
            <div id="messages" class="messages-container">
                @foreach (var msg in Model.Messages)
                {
                    <div class="message @(msg.IsDeleted ? "deleted" : "")" data-id="@msg.Id" data-author-id="@msg.AuthorId" data-author-name="@msg.AuthorUsername" data-sent="@msg.SentAt.ToString("o")">
                        <a href="/App/Profile?userId=@msg.AuthorId" class="message-avatar-link">
                            @if (!string.IsNullOrEmpty(msg.AuthorAvatarUrl))
                            {
                                <img src="@msg.AuthorAvatarUrl" alt="@msg.AuthorUsername" class="message-avatar" />
                            }
                            else
                            {
                                <div class="message-avatar message-avatar-fallback">@msg.AuthorUsername.Substring(0, 1).ToUpper()</div>
                            }
                        </a>
                        @if (msg.ReplyToMessageId.HasValue)
                        {
                            <div class="message-reply-ref" data-reply-to="@msg.ReplyToMessageId">
                                <span class="reply-ref-author">@(msg.ReplyToAuthorUsername ?? "Unknown")</span><span class="reply-ref-preview">@(msg.ReplyToContentPreview ?? "")</span>
                            </div>
                        }
                        <div class="message-author"><a href="/App/Profile?userId=@msg.AuthorId" class="author-link">@msg.AuthorUsername</a> <span class="message-time" data-time="@msg.SentAt.ToString("o")"></span></div>
                        <div class="message-content">@msg.Content</div>
                    </div>
                }
            </div>
            <div id="typing-indicator" class="typing-indicator"></div>
            <div class="message-input-area">
                <div id="mention-list" class="mention-list hidden"></div>
                <div id="emoji-picker" class="emoji-picker hidden"></div>
                <div id="gif-picker" class="gif-picker hidden">
                    <div class="gif-picker-header">
                        <input type="text" id="gif-search" class="emoji-search" placeholder="Search GIFs..." />
                    </div>
                    <div id="gif-grid" class="gif-grid"></div>
                    <div class="gif-attribution">Powered by KLIPY</div>
                </div>
                <!-- Gift modal -->
                <div id="gift-modal" class="gift-modal hidden">
                    <div class="gift-modal-header">Send Orbs</div>
                    <div class="gift-modal-balance">Your balance: <span class="orb-icon"></span> <span id="gift-modal-balance">@Model.OrbBalance</span></div>
                    <label>To:</label>
                    <select id="gift-recipient" class="gift-input">
                        @foreach (var member in Model.MemberData)
                        {
                            <option value="@member.Username" data-user-id="@member.Id">@member.Username</option>
                        }
                    </select>
                    <label>Amount:</label>
                    <input type="number" id="gift-amount" class="gift-input" min="1" placeholder="Amount" />
                    <label>Message (optional):</label>
                    <input type="text" id="gift-message" class="gift-input" placeholder="Nice work!" maxlength="100" autocomplete="off" />
                    <div id="gift-error" class="gift-error hidden"></div>
                    <div class="gift-modal-actions">
                        <button id="gift-cancel" class="btn-secondary btn-sm">Cancel</button>
                        <button id="gift-send" class="btn-primary btn-sm">Send Gift</button>
                    </div>
                </div>
                <form id="message-form">
                    <button type="button" id="emoji-picker-toggle" class="icon-btn emoji-picker-btn" title="Emojis">😀</button>
                    <button type="button" id="gif-picker-toggle" class="icon-btn emoji-picker-btn" title="GIFs">GIF</button>
                    <button type="button" id="gift-toggle" class="icon-btn emoji-picker-btn" title="Gift Orbs">&#x1F381;</button>
                    <input id="message-input" type="text" placeholder="Message #@Model.ChannelName..." autocomplete="off" />
                    <button type="submit">Send</button>
                </form>
            </div>
        }
    </div>

    <!-- Col 4: Members sidebar -->
    <div class="members-sidebar" id="members-sidebar">
        @{
            var onlineMembers = Model.MemberData.Where(m => Model.OnlineMemberIds.Contains(m.Id)).ToList();
            var offlineMembers = Model.MemberData.Where(m => !Model.OnlineMemberIds.Contains(m.Id)).ToList();
        }
        <div class="members-section-header" id="online-count">ONLINE — @onlineMembers.Count</div>
        @foreach (var member in onlineMembers)
        {
            <a href="/App/Profile?userId=@member.Id" class="member-item" data-member-id="@member.Id">
                <div class="avatar-wrapper">
                    @if (!string.IsNullOrEmpty(member.AvatarUrl))
                    {
                        <img src="@member.AvatarUrl" alt="@member.DisplayOrUsername" class="member-avatar" />
                    }
                    else
                    {
                        <div class="member-avatar member-avatar-fallback">@member.DisplayOrUsername.Substring(0, 1).ToUpper()</div>
                    }
                    <span class="presence-dot online"></span>
                </div>
                <span class="member-name">@member.DisplayOrUsername</span>
            </a>
        }
        <div class="members-section-header" id="offline-count">OFFLINE — @offlineMembers.Count</div>
        @foreach (var member in offlineMembers)
        {
            <a href="/App/Profile?userId=@member.Id" class="member-item member-offline" data-member-id="@member.Id">
                <div class="avatar-wrapper">
                    @if (!string.IsNullOrEmpty(member.AvatarUrl))
                    {
                        <img src="@member.AvatarUrl" alt="@member.DisplayOrUsername" class="member-avatar" />
                    }
                    else
                    {
                        <div class="member-avatar member-avatar-fallback">@member.DisplayOrUsername.Substring(0, 1).ToUpper()</div>
                    }
                    <span class="presence-dot offline"></span>
                </div>
                <span class="member-name">@member.DisplayOrUsername</span>
            </a>
        }
    </div>

    <!-- Gift animation container -->
    <div id="gift-animation-container" class="gift-animation-container"></div>

</div>

@section Scripts {
    <script>
        // Invite banner dismiss (per-server, persisted in localStorage)
        const _inviteSection = document.getElementById('invite-section');
        const _inviteBanner = document.getElementById('welcome-invite-banner');
        const _inviteDismiss = document.getElementById('invite-dismiss');
        const _inviteKey = 'invite-dismissed-@Model.ServerId';
        function _dismissInvite() {
            if (_inviteSection) _inviteSection.style.display = 'none';
            if (_inviteBanner) _inviteBanner.style.display = 'none';
            localStorage.setItem(_inviteKey, '1');
        }
        if (localStorage.getItem(_inviteKey)) _dismissInvite();
        _inviteDismiss?.addEventListener('click', _dismissInvite);
    </script>
    <script>
        let channelId = '@Model.ChannelId';
        const serverId = '@Model.ServerId';
        let isVoiceChannel = @(Model.ChannelType == 1 ? "true" : "false");
        const channelName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChannelName));
        const canDeleteMessages = @((Model.CurrentUserRole >= peeposredemption.Domain.Entities.ServerRole.Moderator).ToString().ToLower());
        const memberUsernames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MemberUsernames));
        const memberData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MemberData));
        const currentUserRole = @((int)Model.CurrentUserRole);
        const currentUserId = '@Model.CurrentUserId';
        const currentUsername = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CurrentUsername));
    </script>
    <script src="~/js/chat.js" asp-append-version="true"></script>
    @if (Model.ChannelType == 1)
    {
        <script src="~/js/voice.js" asp-append-version="true"></script>
    }
    <script>
        if (isVoiceChannel) {
            // Voice channels only need the add-channel-toggle and VoiceChannelState sidebar handler
            document.getElementById('add-channel-toggle').addEventListener('click', () => {
                document.getElementById('add-channel-section').classList.toggle('hidden');
            });
            // VoiceChannelState sidebar updates handled by voice.js + chat.js
        }
        if (!isVoiceChannel) {
        // Format times and insert date separators using client local time
        (function() {
            const container = document.getElementById('messages');
            if (!container) return;
            const msgs = Array.from(container.querySelectorAll('.message[data-sent]'));
            let lastDateKey = null;
            let lastAuthorId = null;
            let lastMsgTime = null;
            msgs.forEach(el => {
                const sent = new Date(el.dataset.sent);
                const key = getDateKey(el.dataset.sent);
                // Insert date separator before this message if date changed
                if (key !== lastDateKey) {
                    const sep = document.createElement('div');
                    sep.className = 'date-separator';
                    sep.dataset.dateKey = key;
                    sep.innerHTML = `<span>${getDateLabel(el.dataset.sent)}</span>`;
                    container.insertBefore(sep, el);
                    lastDateKey = key;
                    lastAuthorId = null;
                    lastMsgTime = null;
                }
                // Message grouping
                const authorId = el.dataset.authorId;
                if (lastAuthorId === authorId && lastMsgTime && (sent - lastMsgTime) < 5 * 60 * 1000) {
                    el.classList.add('message-grouped');
                    el.dataset.groupedTime = sent.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                }
                lastAuthorId = authorId;
                lastMsgTime = sent;
                // Format time
                const timeEl = el.querySelector('.message-time');
                if (timeEl && timeEl.dataset.time) {
                    timeEl.textContent = ' \u2014 ' + new Date(timeEl.dataset.time).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                }
            });
            // Highlight messages that mention the current user
            try { highlightServerRenderedMentions(); } catch(e) { console.error('highlightServerRenderedMentions:', e); }
            // Wire up click-to-scroll for server-rendered reply refs
            document.querySelectorAll('.message-reply-ref[data-reply-to]').forEach(ref => {
                ref.addEventListener('click', () => {
                    const target = document.querySelector(`[data-id="${ref.dataset.replyTo}"]`);
                    if (target) {
                        target.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        target.classList.add('message-highlight');
                        setTimeout(() => target.classList.remove('message-highlight'), 1500);
                    }
                });
            });
        })();
        document.getElementById('add-channel-toggle').addEventListener('click', () => {
            document.getElementById('add-channel-section').classList.toggle('hidden');
        });

        // Emoji rendering and picker — cross-server
        let allEmojis = []; // all emojis from all user servers
        let emojiMap = new Map(); // name → emoji (current server wins)

        function buildEmojiMap() {
            emojiMap.clear();
            // Current server emojis take priority — add them last so they overwrite
            const otherServer = allEmojis.filter(e => e.serverId !== serverId);
            const thisServer = allEmojis.filter(e => e.serverId === serverId);
            otherServer.forEach(e => emojiMap.set(e.name, e));
            thisServer.forEach(e => emojiMap.set(e.name, e));
        }

        function renderEmojis(text) {
            if (!emojiMap.size) return text;
            return text.replace(/:([a-z0-9_]{2,32}):/g, (match, name) => {
                const emoji = emojiMap.get(name);
                if (!emoji) return match;
                return `<img src="${emoji.imageUrl}" alt=":${name}:" class="inline-emoji" title=":${name}: (${emoji.serverName})" />`;
            });
        }

        function applyEmojiRendering() {
            document.querySelectorAll('.message-content').forEach(el => {
                if (!el.dataset.emojiRendered && !el.dataset.gifRendered) {
                    el.innerHTML = renderEmojis(el.textContent);
                    el.dataset.emojiRendered = '1';
                }
                // Twemoji: replace unicode emoji with CDN images
                if (window.twemoji) twemoji.parse(el, { folder: 'svg', ext: '.svg' });
            });
