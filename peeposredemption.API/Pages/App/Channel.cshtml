@page
@model peeposredemption.API.Pages.App.ChannelModel
@{
    ViewData["Title"] = Model.ChannelName;
}

<div class="app-shell">

    <!-- Col 1: Server icon strip -->
    <partial name="_ServerList" model="Model.ServerList" />

    <!-- Col 2: Channel list -->
    <div class="sidebar">
        <div class="sidebar-header server-name-header">
            <span>@Model.ServerName</span>
            @if (Model.CurrentUserRole == peeposredemption.Domain.Entities.ServerRole.Owner)
            {
                <a href="/App/ServerSettings?serverId=@Model.ServerId" class="icon-btn" title="Server Settings">⚙</a>
            }
        </div>

        @if (Model.InviteLink != null)
        {
            <div class="invite-section">
                <span class="invite-label">Invite</span>
                <a href="@Model.InviteLink" class="invite-link" title="@Model.InviteLink">Copy Link</a>
            </div>
        }

        <div class="sidebar-section-header">
            CHANNELS
            <button class="icon-btn" id="add-channel-toggle" title="Create Channel">+</button>
        </div>
        <div id="add-channel-section" class="hidden">
            <form method="post" asp-page-handler="CreateChannel" class="add-friend-form">
                <input type="hidden" name="serverId" value="@Model.ServerId" />
                <input type="text" name="name" placeholder="new-channel" required maxlength="100" autocomplete="off" />
                <button type="submit" class="btn-primary btn-sm">Create</button>
            </form>
        </div>
        @foreach (var ch in Model.Channels)
        {
            <div class="channel-row">
                <a href="/App/Channel?channelId=@ch.Id&serverId=@Model.ServerId"
                   class="channel-item @(ch.Id == Model.ChannelId ? "active" : "")">
                    <span class="channel-hash">#</span>
                    <span>@ch.Name</span>
                </a>
                @if (Model.CurrentUserRole >= peeposredemption.Domain.Entities.ServerRole.Moderator && ch.Name != "general")
                {
                    <form method="post" asp-page-handler="DeleteChannel" class="channel-delete-form">
                        <input type="hidden" name="channelId" value="@ch.Id" />
                        <input type="hidden" name="serverId" value="@Model.ServerId" />
                        <button type="submit" class="icon-btn channel-delete-btn" title="Delete channel">✕</button>
                    </form>
                }
            </div>
        }
    </div>

    <!-- Col 3: Messages -->
    <div class="content-area">
        <div class="content-header">
            <span class="channel-hash">#</span>
            <span>@Model.ChannelName</span>
        </div>
        <div id="messages" class="messages-container">
            @{
                DateTime? lastDate = null;
            }
            @foreach (var msg in Model.Messages)
            {
                var msgDate = msg.SentAt.Date;
                if (lastDate == null || lastDate != msgDate)
                {
                    <div class="date-separator">
                        <span>@msg.SentAt.ToString("dddd, MMMM d, yyyy")</span>
                    </div>
                    lastDate = msgDate;
                }
                <div class="message @(msg.IsDeleted ? "deleted" : "")" data-id="@msg.Id">
                    <div class="message-author">@msg.AuthorUsername</div>
                    <div class="message-content">@msg.Content</div>
                    <div class="message-time" data-time="@msg.SentAt.ToString("o")"></div>
                    @if (Model.CurrentUserRole >= peeposredemption.Domain.Entities.ServerRole.Moderator && !msg.IsDeleted)
                    {
                        <button class="icon-btn msg-delete-btn" data-msg-id="@msg.Id" title="Delete message">🗑</button>
                    }
                </div>
            }
        </div>
        <div id="typing-indicator" class="typing-indicator"></div>
        <div class="message-input-area">
            <div id="mention-list" class="mention-list hidden"></div>
            <div id="emoji-picker" class="emoji-picker hidden"></div>
            <form id="message-form">
                <button type="button" id="emoji-picker-toggle" class="icon-btn emoji-picker-btn" title="Emojis">😀</button>
                <input id="message-input" type="text" placeholder="Message #@Model.ChannelName..." autocomplete="off" />
                <button type="submit">Send</button>
            </form>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const channelId = '@Model.ChannelId';
        const serverId = '@Model.ServerId';
        const canDeleteMessages = @((Model.CurrentUserRole >= peeposredemption.Domain.Entities.ServerRole.Moderator).ToString().ToLower());
        const memberUsernames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MemberUsernames));
    </script>
    <script src="~/js/chat.js"></script>
    <script>
        document.querySelectorAll('.message-time[data-time]').forEach(el => {
            el.textContent = new Date(el.dataset.time).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        });
        document.getElementById('add-channel-toggle').addEventListener('click', () => {
            document.getElementById('add-channel-section').classList.toggle('hidden');
        });

        // Emoji rendering and picker
        let serverEmojis = [];

        function renderEmojis(text) {
            if (!serverEmojis.length) return text;
            return text.replace(/:([a-z0-9_]{2,32}):/g, (match, name) => {
                const emoji = serverEmojis.find(e => e.name === name);
                if (!emoji) return match;
                return `<img src="${emoji.imageUrl}" alt=":${name}:" class="inline-emoji" title=":${name}:" />`;
            });
        }

        function applyEmojiRendering() {
            document.querySelectorAll('.message-content').forEach(el => {
                if (!el.dataset.emojiRendered) {
                    el.innerHTML = renderEmojis(el.textContent);
                    el.dataset.emojiRendered = '1';
                }
            });
        }

        function buildEmojiPicker() {
            const picker = document.getElementById('emoji-picker');
            picker.innerHTML = '';
            if (!serverEmojis.length) {
                picker.innerHTML = '<span class="emoji-picker-empty">No custom emojis</span>';
                return;
            }
            serverEmojis.forEach(e => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.title = `:${e.name}:`;
                btn.innerHTML = `<img src="${e.imageUrl}" alt=":${e.name}:" class="inline-emoji" />`;
                btn.addEventListener('click', () => {
                    const input = document.getElementById('message-input');
                    input.value += `:${e.name}:`;
                    input.focus();
                    picker.classList.add('hidden');
                });
                picker.appendChild(btn);
            });
        }

        document.getElementById('emoji-picker-toggle').addEventListener('click', (e) => {
            e.stopPropagation();
            document.getElementById('emoji-picker').classList.toggle('hidden');
        });

        document.addEventListener('click', () => {
            document.getElementById('emoji-picker').classList.add('hidden');
        });

        document.getElementById('emoji-picker').addEventListener('click', e => e.stopPropagation());

        // Fetch server emojis and render
        fetch(`/api/servers/${serverId}/emojis`)
            .then(r => r.json())
            .then(data => {
                serverEmojis = data;
                buildEmojiPicker();
                applyEmojiRendering();
            })
            .catch(() => {});

        // Expose so chat.js can call it when new real-time messages arrive
        window.applyEmojiRendering = applyEmojiRendering;

        // ── @@mention autocomplete ──────────────────────────────
        const mentionList = document.getElementById('mention-list');
        const msgInput = document.getElementById('message-input');

        msgInput.addEventListener('input', () => {
            const val = msgInput.value;
            const atIdx = val.lastIndexOf('@@');
            if (atIdx === -1 || (atIdx > 0 && !/\s/.test(val[atIdx - 1]))) {
                mentionList.classList.add('hidden');
                return;
            }
            const query = val.slice(atIdx + 1).toLowerCase();
            const matches = memberUsernames.filter(u => u.toLowerCase().startsWith(query) && query.length >= 0);
            if (!matches.length || query.includes(' ')) {
                mentionList.classList.add('hidden');
                return;
            }
            mentionList.innerHTML = '';
            matches.slice(0, 8).forEach(u => {
                const item = document.createElement('div');
                item.className = 'mention-item';
                item.textContent = '@@' + u;
                item.addEventListener('mousedown', (e) => {
                    e.preventDefault();
                    const before = val.slice(0, atIdx);
                    msgInput.value = before + '@@' + u + ' ';
                    mentionList.classList.add('hidden');
                    msgInput.focus();
                });
                mentionList.appendChild(item);
            });
            mentionList.classList.remove('hidden');
        });

        msgInput.addEventListener('keydown', (e) => {
            if (mentionList.classList.contains('hidden')) return;
            const items = mentionList.querySelectorAll('.mention-item');
            const active = mentionList.querySelector('.mention-item.active');
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                const next = active ? active.nextElementSibling : items[0];
                active?.classList.remove('active');
                next?.classList.add('active');
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                const prev = active ? active.previousElementSibling : items[items.length - 1];
                active?.classList.remove('active');
                prev?.classList.add('active');
            } else if (e.key === 'Enter' || e.key === 'Tab') {
                if (active) {
                    e.preventDefault();
                    active.dispatchEvent(new MouseEvent('mousedown'));
                }
            } else if (e.key === 'Escape') {
                mentionList.classList.add('hidden');
            }
        });

        document.addEventListener('click', () => mentionList.classList.add('hidden'));

        // ── Real-time notification badge ───────────────────────
        const homeBadge = document.querySelector('.home-icon .notif-badge');

        if (typeof connection !== 'undefined') {
            connection.on('ReceiveNotification', (notif) => {
                // Increment badge or show it
                const badge = document.querySelector('.home-icon .notif-badge');
                if (badge) {
                    const current = parseInt(badge.textContent) || 0;
                    badge.textContent = current >= 9 ? '9+' : (current + 1).toString();
                } else {
                    const icon = document.querySelector('.home-icon');
                    if (icon) {
                        const b = document.createElement('span');
                        b.className = 'notif-badge';
                        b.textContent = '1';
                        icon.appendChild(b);
                    }
                }
                // Brief flash on the badge
                document.querySelector('.home-icon .notif-badge')?.classList.add('notif-pulse');
                setTimeout(() => document.querySelector('.home-icon .notif-badge')?.classList.remove('notif-pulse'), 600);
            });
        }
    </script>
}
