@page
@model peeposredemption.API.Pages.App.Admin.SecurityAdminModel
@{
    ViewData["Title"] = "Admin — Security";
}

<div class="app-shell">
    <div class="sidebar">
        <div class="sidebar-header">
            <a href="/App/Index" class="icon-btn" title="Back">&#8592;</a>
            <span>Security</span>
        </div>
        <div class="sidebar-section-header">ADMIN</div>
        <a href="/App/Admin/SecurityAdmin" class="channel-item active">Security</a>
        <a href="/App/Admin/BanAdmin" class="channel-item">Bans & Servers</a>
        <a href="/App/Admin/Referrals" class="channel-item">Referrals</a>
        <a href="/App/Admin/ArtistAdmin" class="channel-item">Artists</a>
        <a href="/App/Admin/FeatureRequestAdmin" class="channel-item">Feature Requests</a>
        <a href="/App/Admin/SupportTicketAdmin" class="channel-item">Support Tickets</a>
    </div>

    <div class="sidebar-backdrop"></div>

    <div class="content-area settings-page">
        <div class="content-header">
            <button class="mobile-menu-btn" aria-label="Open menu">&#9776;</button>
            <span>Security</span>
        </div>

        <div class="settings-body admin-body">
        <!-- IP Bans -->
        <section class="settings-section">
            <h3 class="settings-heading">IP BANS</h3>

            <div class="admin-form-row">
                <input type="text" id="ban-ip-input" placeholder="IP address" class="settings-input" style="flex:1" />
                <input type="text" id="ban-ip-reason" placeholder="Reason (optional)" class="settings-input" style="flex:1" />
                <button id="ban-ip-btn" class="btn btn-danger" style="white-space:nowrap">Ban IP</button>
            </div>

            @if (Model.IpBans.Any())
            {
                <div class="admin-table-wrap">
                <table class="audit-table" style="width:100%">
                    <thead><tr><th>IP</th><th>Reason</th><th>Banned By</th><th>Date</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var ban in Model.IpBans)
                        {
                            <tr data-ban-id="@ban.Id">
                                <td>@ban.IpAddress</td>
                                <td>@(ban.Reason ?? "—")</td>
                                <td>@ban.BannedByUsername</td>
                                <td>@ban.CreatedAt.ToString("MMM d, yyyy")</td>
                                <td><button class="btn btn-sm unban-ip-btn" data-id="@ban.Id">Unban</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
            }
            else
            {
                <p style="color:#72767d">No IP bans.</p>
            }
        </section>

        <!-- Login Lockout -->
        <section class="settings-section" style="margin-top:24px">
            <h3 class="settings-heading">LOGIN LOCKOUT</h3>
            <div class="admin-form-row">
                <input type="text" id="lockout-ip-input" placeholder="IP address to unlock" class="settings-input" style="flex:1" />
                <button id="clear-lockout-btn" class="btn btn-primary" style="white-space:nowrap">Clear Lockout</button>
            </div>
            <p id="lockout-msg" style="margin-top:8px;font-size:13px;color:#72767d;display:none"></p>
        </section>

        <!-- User Security Overview -->
        <section class="settings-section" style="margin-top:24px">
            <h3 class="settings-heading">USER SECURITY</h3>

            <input type="text" id="user-search" placeholder="Search by username..." class="settings-input" style="margin-bottom:16px;max-width:300px" />

            <div class="admin-table-wrap">
            <table class="audit-table" style="width:100%" id="users-table">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Last IP</th>
                        <th>VPN</th>
                        <th>Tor</th>
                        <th>Devices</th>
                        <th>Logins</th>
                        <th>Suspicious</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr data-username="@user.Username.ToLower()" data-user-id="@user.UserId">
                            <td>@user.Username</td>
                            <td style="font-family:monospace;font-size:12px">@(user.LastIp ?? "—")</td>
                            <td>@(user.IsVpn ? "YES" : "—")</td>
                            <td>@(user.IsTor ? "YES" : "—")</td>
                            <td>@user.DeviceCount</td>
                            <td>@user.LoginCount</td>
                            <td>
                                @if (user.IsSuspicious)
                                {
                                    <span style="color:#ed4245">FLAGGED</span>
                                }
                                else
                                {
                                    <span style="color:#72767d">—</span>
                                }
                            </td>
                            <td style="display:flex;gap:4px;flex-wrap:wrap">
                                <button class="btn btn-sm view-details-btn" data-id="@user.UserId">Details</button>
                                <button class="btn btn-sm view-sessions-btn" data-id="@user.UserId" data-name="@user.Username">Sessions</button>
                                <button class="btn btn-sm toggle-suspicious-btn"
                                        data-id="@user.UserId"
                                        data-current="@user.IsSuspicious.ToString().ToLower()">
                                    @(user.IsSuspicious ? "Unflag" : "Flag")
                                </button>
                                @if (!string.IsNullOrEmpty(user.LastIp))
                                {
                                    <button class="btn btn-sm btn-danger ban-user-ip-btn" data-ip="@user.LastIp">Ban IP</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </section>

        <!-- Alt Detection Panel (heuristic, live compute) -->
        <section class="settings-section" style="margin-top:24px">
            <h3 class="settings-heading">ALT DETECTION — CONFIDENCE SCORES</h3>
            <p style="color:#72767d;margin-bottom:12px;font-size:13px">Pairs with score ≥ 40 are shown. Score is capped at 99.</p>
            <button id="load-alt-suspects-btn" class="btn btn-sm">Load Alt Suspects</button>
            <div id="alt-suspects-container" style="margin-top:12px"></div>
        </section>

        <!-- Alt Suspicions Panel (DB-persisted, from Run Alt Scan) -->
        <section class="settings-section" style="margin-top:24px">
            <h3 class="settings-heading">ALT SUSPICIONS — REVIEW QUEUE</h3>
            <p style="color:#72767d;margin-bottom:12px;font-size:13px">Pending pairs from last scan. Run scan to populate.</p>
            <div style="display:flex;gap:8px;margin-bottom:12px">
                <button id="run-alt-scan-btn" class="btn btn-sm">Run Alt Scan</button>
                <button id="load-alt-suspicions-btn" class="btn btn-sm">Load Pending</button>
            </div>
            <div id="run-scan-status" style="display:none;font-size:13px;color:#faa61a;margin-bottom:8px"></div>
            <div id="alt-suspicions-container"></div>
        </section>

        <!-- Scam Flags Panel -->
        <section class="settings-section" style="margin-top:24px">
            <h3 class="settings-heading">SCAM FLAGS</h3>
            <p style="color:#72767d;margin-bottom:12px;font-size:13px">Users automatically flagged as suspicious by scam detection.</p>
            @if (Model.ScamFlags.Any())
            {
                <div class="admin-table-wrap">
                <table class="audit-table" style="width:100%">
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Account Age</th>
                            <th>DMs (24h)</th>
                            <th>Tor</th>
                            <th>VPN</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model.ScamFlags)
                        {
                            <tr>
                                <td>@u.Username</td>
                                <td>@u.AccountAgeDays days</td>
                                <td>@u.DmsSentLast24h</td>
                                <td>@(u.IsTor ? "YES" : "—")</td>
                                <td>@(u.IsVpn ? "YES" : "—")</td>
                                <td style="display:flex;gap:4px;flex-wrap:wrap">
                                    <button class="btn btn-sm toggle-suspicious-btn"
                                            data-id="@u.UserId"
                                            data-current="true">Unflag</button>
                                    @if (!string.IsNullOrEmpty(u.LastIp))
                                    {
                                        <button class="btn btn-sm btn-danger ban-user-ip-btn" data-ip="@u.LastIp">Ban IP</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
            }
            else
            {
                <p style="color:#3ba55c">No scam flags.</p>
            }
        </section>

        <!-- User Detail Panel -->
        <div id="detail-panel" style="display:none;margin-top:24px">
            <section class="settings-section">
                <h3 class="settings-heading" id="detail-username">USER DETAILS</h3>
                <div id="detail-content" style="color:#dcddde"></div>
            </section>
        </div>

        <!-- Sessions Panel -->
        <div id="sessions-panel" style="display:none;margin-top:24px">
            <section class="settings-section">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
                    <h3 class="settings-heading" id="sessions-username" style="margin:0">SESSIONS</h3>
                    <button class="btn btn-danger btn-sm" id="admin-revoke-all-btn">Revoke All</button>
                </div>
                <div id="sessions-content" style="display:flex;flex-direction:column;gap:8px"></div>
            </section>
        </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const jwt = document.querySelector('meta[name="jwt"]')?.content;
    const headers = { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + jwt };

    // Search filter
    document.getElementById('user-search').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#users-table tbody tr').forEach(row => {
            row.style.display = row.dataset.username.includes(q) ? '' : 'none';
        });
    });

    // Clear login lockout
    document.getElementById('clear-lockout-btn').addEventListener('click', async () => {
        const ip = document.getElementById('lockout-ip-input').value.trim();
        const msg = document.getElementById('lockout-msg');
        if (!ip) return;
        const res = await fetch('/api/admin/security/clear-login-lockout', {
            method: 'POST', headers, body: JSON.stringify({ ipAddress: ip })
        });
        msg.style.display = 'block';
        msg.style.color = res.ok ? '#23a55a' : '#f04747';
        msg.textContent = res.ok ? `Lockout cleared for ${ip}.` : 'Failed to clear lockout.';
    });

    // Ban IP
    document.getElementById('ban-ip-btn').addEventListener('click', async () => {
        const ip = document.getElementById('ban-ip-input').value.trim();
        const reason = document.getElementById('ban-ip-reason').value.trim();
        if (!ip) return;
        const res = await fetch('/api/admin/security/ip-ban', {
            method: 'POST', headers, body: JSON.stringify({ ipAddress: ip, reason: reason || null })
        });
        if (res.ok) location.reload();
        else alert('Failed to ban IP');
    });

    // Unban IP
    document.querySelectorAll('.unban-ip-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            const id = btn.dataset.id;
            const res = await fetch('/api/admin/security/ip-ban/' + id, { method: 'DELETE', headers });
            if (res.ok) btn.closest('tr').remove();
        });
    });

    // Ban user's IP (from user table)
    document.querySelectorAll('.ban-user-ip-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            const ip = btn.dataset.ip;
            if (!confirm('Ban IP ' + ip + '?')) return;
            const res = await fetch('/api/admin/security/ip-ban', {
                method: 'POST', headers, body: JSON.stringify({ ipAddress: ip, reason: 'Banned from security dashboard' })
            });
            if (res.ok) location.reload();
        });
    });

    // Toggle suspicious
    document.querySelectorAll('.toggle-suspicious-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            const userId = btn.dataset.id;
            const current = btn.dataset.current === 'true';
            const res = await fetch('/api/admin/security/toggle-suspicious', {
                method: 'POST', headers, body: JSON.stringify({ targetUserId: userId, isSuspicious: !current })
            });
            if (res.ok) location.reload();
        });
    });

    // View details
    document.querySelectorAll('.view-details-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            const userId = btn.dataset.id;
            const res = await fetch('/api/admin/security/user/' + userId, { headers });
            if (!res.ok) return;
            const data = await res.json();
            const panel = document.getElementById('detail-panel');
            document.getElementById('detail-username').textContent = data.username.toUpperCase() + ' — SECURITY DETAILS';

            let html = '';

            // IP logs
            html += '<h4 style="margin:12px 0 8px;color:#f2f3f5">IP History</h4>';
            if (data.ipLogs.length) {
                html += '<table class="audit-table" style="width:100%"><thead><tr><th>IP</th><th>VPN</th><th>Tor</th><th>Date</th></tr></thead><tbody>';
                data.ipLogs.forEach(l => {
                    html += `<tr><td style="font-family:monospace">${l.ipAddress}</td><td>${l.isVpn ? 'YES' : '—'}</td><td>${l.isTor ? 'YES' : '—'}</td><td>${new Date(l.seenAt).toLocaleString()}</td></tr>`;
                });
                html += '</tbody></table>';
            } else html += '<p style="color:#72767d">No IP data.</p>';

            // Devices
            html += '<h4 style="margin:12px 0 8px;color:#f2f3f5">Devices</h4>';
            if (data.devices.length) {
                html += '<table class="audit-table" style="width:100%"><thead><tr><th>Device ID</th><th>First Seen</th><th>Last Seen</th><th>Banned</th><th></th></tr></thead><tbody>';
                data.devices.forEach(d => {
                    html += `<tr><td style="font-family:monospace;font-size:11px">${d.deviceId}</td><td>${new Date(d.firstSeenAt).toLocaleString()}</td><td>${new Date(d.lastSeenAt).toLocaleString()}</td><td>${d.isBanned ? 'YES' : '—'}</td>`;
                    html += `<td><button class="btn btn-sm btn-danger device-ban-btn" data-device="${d.deviceId}">${d.isBanned ? 'Unban' : 'Ban'}</button></td></tr>`;
                });
                html += '</tbody></table>';
            } else html += '<p style="color:#72767d">No devices.</p>';

            // Fingerprints
            if (data.fingerprints.length) {
                html += '<h4 style="margin:12px 0 8px;color:#f2f3f5">Fingerprints</h4>';
                html += '<table class="audit-table" style="width:100%"><thead><tr><th>Hash</th><th>Date</th><th>Details</th></tr></thead><tbody>';
                data.fingerprints.forEach((f, i) => {
                    let detailsHtml = '—';
                    if (f.rawComponents) {
                        try {
                            const c = JSON.parse(f.rawComponents);
                            const labels = {
                                webglRenderer: 'GPU',
                                webglVendor: 'GPU Vendor',
                                screenWidth: 'Screen W',
                                screenHeight: 'Screen H',
                                colorDepth: 'Color Depth',
                                timezoneOffset: 'Timezone Offset',
                                language: 'Language',
                                platform: 'Platform',
                                hardwareConcurrency: 'CPU Cores'
                            };
                            const rows = Object.entries(labels)
                                .filter(([k]) => c[k] !== undefined && c[k] !== '')
                                .map(([k, label]) => `<tr><td style="color:#949ba4;padding:2px 8px 2px 0">${label}</td><td style="font-family:monospace;font-size:11px">${c[k]}</td></tr>`)
                                .join('');
                            const expandId = `fp-expand-${i}`;
                            detailsHtml = `<button onclick="const el=document.getElementById('${expandId}');el.style.display=el.style.display==='none'?'block':'none'" class="btn btn-sm">Expand</button>
                                <div id="${expandId}" style="display:none;margin-top:6px;background:#1e1f22;border-radius:6px;padding:8px">
                                    <table style="border-collapse:collapse">${rows}</table>
                                </div>`;
                        } catch (_) {}
                    }
                    html += `<tr>
                        <td style="font-family:monospace;font-size:11px">${f.fingerprintHash}</td>
                        <td>${new Date(f.createdAt).toLocaleString()}</td>
                        <td>${detailsHtml}</td>
                    </tr>`;
                });
                html += '</tbody></table>';
            }

            // Linked accounts
            html += '<h4 style="margin:12px 0 8px;color:#f2f3f5">Linked Accounts (Alt Detection)</h4>';
            if (data.linkedAccounts.length) {
                html += '<table class="audit-table" style="width:100%"><thead><tr><th>Username</th><th>Match Type</th><th>Match Value</th></tr></thead><tbody>';
                data.linkedAccounts.forEach(a => {
                    html += `<tr><td>${a.username}</td><td>${a.matchType}</td><td style="font-family:monospace;font-size:11px">${a.matchValue}</td></tr>`;
                });
                html += '</tbody></table>';
            } else html += '<p style="color:#3ba55c">No linked accounts found.</p>';

            document.getElementById('detail-content').innerHTML = html;
            panel.style.display = 'block';
            panel.scrollIntoView({ behavior: 'smooth' });

            // Bind device ban buttons
            document.querySelectorAll('.device-ban-btn').forEach(dbtn => {
                dbtn.addEventListener('click', async () => {
                    const deviceId = dbtn.dataset.device;
                    const isBanned = dbtn.textContent.trim() === 'Unban';
                    const url = isBanned
                        ? '/api/admin/security/device-ban/' + deviceId
                        : '/api/admin/security/device-ban';
                    const method = isBanned ? 'DELETE' : 'POST';
                    const body = isBanned ? undefined : JSON.stringify({ deviceId });
                    const res = await fetch(url, { method, headers, body });
                    if (res.ok) location.reload();
                });
            });
        });
    });

    // ── Admin Session Management ──
    let activeSessionUserId = null;

    document.querySelectorAll('.view-sessions-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            activeSessionUserId = btn.dataset.id;
            const name = btn.dataset.name;
            document.getElementById('sessions-username').textContent = name.toUpperCase() + ' — SESSIONS';
            const panel = document.getElementById('sessions-panel');
            const content = document.getElementById('sessions-content');
            content.innerHTML = '<p style="color:#949ba4">Loading...</p>';
            panel.style.display = 'block';

            const res = await fetch('/api/admin/sessions/' + activeSessionUserId, { headers });
            if (!res.ok) { content.innerHTML = '<p style="color:#ed4245">Failed to load.</p>'; return; }
            const sessions = await res.json();
            if (!sessions.length) { content.innerHTML = '<p style="color:#949ba4">No active sessions.</p>'; return; }

            content.innerHTML = sessions.map(s => `
                <div class="session-card" data-id="${s.id}">
                    <div class="session-icon">&#128187;</div>
                    <div class="session-info">
                        <div class="session-title">${s.browser || 'Unknown'} on ${s.os || 'Unknown'}</div>
                        <div class="session-meta">
                            ${s.ipAddress ? `<span>${s.ipAddress}</span>` : ''}
                            <span>${new Date(s.createdAt + 'Z').toLocaleString()}</span>
                        </div>
                    </div>
                    <button class="btn btn-sm btn-danger admin-revoke-session" data-id="${s.id}">Revoke</button>
                </div>
            `).join('');

            content.querySelectorAll('.admin-revoke-session').forEach(rb => {
                rb.addEventListener('click', async () => {
                    const res = await fetch('/api/admin/sessions/' + activeSessionUserId + '/' + rb.dataset.id, { method: 'DELETE', headers });
                    if (res.ok) rb.closest('.session-card').remove();
                });
            });

            panel.scrollIntoView({ behavior: 'smooth' });
        });
    });

    document.getElementById('admin-revoke-all-btn').addEventListener('click', async () => {
        if (!activeSessionUserId || !confirm('Revoke ALL sessions for this user?')) return;
        const res = await fetch('/api/admin/sessions/' + activeSessionUserId + '/revoke-all', { method: 'POST', headers });
        if (res.ok) {
            document.getElementById('sessions-content').innerHTML = '<p style="color:#949ba4">All sessions revoked.</p>';
        }
    });

    // ── Alt Detection (heuristic) ──
    document.getElementById('load-alt-suspects-btn').addEventListener('click', async () => {
        const container = document.getElementById('alt-suspects-container');
        container.innerHTML = '<p style="color:#949ba4">Loading…</p>';
        const res = await fetch('/api/admin/alt-suspects', { headers });
        if (!res.ok) { container.innerHTML = '<p style="color:#ed4245">Failed to load.</p>'; return; }
        const pairs = await res.json();
        if (!pairs.length) {
            container.innerHTML = '<p style="color:#3ba55c">No alt suspects detected.</p>';
            return;
        }
        let html = '<table class="audit-table" style="width:100%"><thead><tr><th>User A</th><th>User B</th><th>Score</th><th>Signals</th></tr></thead><tbody>';
        pairs.forEach(p => {
            const scoreColor = p.score >= 80 ? '#ed4245' : p.score >= 60 ? '#faa61a' : '#dcddde';
            html += `<tr>
                <td><a href="/App/Admin/SecurityAdmin?highlight=${p.userAId}" style="color:#00b0f4">${p.userAName}</a></td>
                <td><a href="/App/Admin/SecurityAdmin?highlight=${p.userBId}" style="color:#00b0f4">${p.userBName}</a></td>
                <td style="font-weight:bold;color:${scoreColor}">${p.score}%</td>
                <td style="font-size:12px;color:#949ba4">${p.matchReasons.join(' · ')}</td>
            </tr>`;
        });
        html += '</tbody></table>';
        container.innerHTML = html;
    });

    // ── Alt Scan + Suspicions Queue ──
    document.getElementById('run-alt-scan-btn').addEventListener('click', async () => {
        const status = document.getElementById('run-scan-status');
        status.style.display = 'block';
        status.textContent = 'Running scan… this may take a moment.';
        const res = await fetch('/api/admin/security/run-alt-scan', { method: 'POST', headers });
        if (!res.ok) { status.textContent = 'Scan failed.'; status.style.color = '#ed4245'; return; }
        const data = await res.json();
        status.style.color = '#3ba55c';
        status.textContent = `Scan complete. ${data.newRecords} new suspicion record(s) added.`;
    });

    document.getElementById('load-alt-suspicions-btn').addEventListener('click', loadAltSuspicions);

    async function loadAltSuspicions() {
        const container = document.getElementById('alt-suspicions-container');
        container.innerHTML = '<p style="color:#949ba4">Loading…</p>';
        const res = await fetch('/api/admin/alt-suspicions', { headers });
        if (!res.ok) { container.innerHTML = '<p style="color:#ed4245">Failed to load.</p>'; return; }
        const items = await res.json();
        if (!items.length) {
            container.innerHTML = '<p style="color:#3ba55c">No pending suspicions. Run a scan first.</p>';
            return;
        }

        let html = `<table class="audit-table" style="width:100%">
            <thead><tr><th>User 1</th><th>User 2</th><th>Score</th><th>Signals</th><th>Detected</th><th>Actions</th></tr></thead>
            <tbody>`;
        items.forEach(s => {
            const scoreColor = s.score >= 80 ? '#ed4245' : s.score >= 60 ? '#faa61a' : '#dcddde';
            html += `<tr data-suspicion-id="${s.id}">
                <td style="color:#00b0f4">${s.username1}</td>
                <td style="color:#00b0f4">${s.username2}</td>
                <td style="font-weight:bold;color:${scoreColor}">${s.score}</td>
                <td style="font-size:11px;color:#949ba4">${s.signals.join(' · ')}</td>
                <td style="font-size:12px">${new Date(s.detectedAt).toLocaleDateString()}</td>
                <td style="display:flex;gap:4px;flex-wrap:wrap">
                    <button class="btn btn-sm review-suspicion-btn" data-action="confirm" data-id="${s.id}" style="color:#3ba55c">Confirm</button>
                    <button class="btn btn-sm review-suspicion-btn" data-action="dismiss" data-id="${s.id}">Dismiss</button>
                    <button class="btn btn-sm btn-danger review-suspicion-btn" data-action="ban" data-id="${s.id}">Ban Both</button>
                </td>
            </tr>`;
        });
        html += '</tbody></table>';
        container.innerHTML = html;

        container.querySelectorAll('.review-suspicion-btn').forEach(btn => {
            btn.addEventListener('click', async () => {
                const id = btn.dataset.id;
                const action = btn.dataset.action;
                if (action === 'ban' && !confirm('Flag both users as suspicious?')) return;
                const res = await fetch(`/api/admin/alt-suspicions/${id}/review`, {
                    method: 'POST', headers, body: JSON.stringify({ action })
                });
                if (res.ok) {
                    btn.closest('tr').remove();
                    if (!container.querySelector('tr')) {
                        container.innerHTML = '<p style="color:#3ba55c">All suspicions reviewed.</p>';
                    }
                } else {
                    alert('Action failed.');
                }
            });
        });
    }
</script>
}
