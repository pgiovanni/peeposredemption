@page
@model peeposredemption.API.Pages.App.IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="app-shell">

    <!-- Col 1: Server icon strip -->
    <partial name="_ServerList" model="Model.ServerList" />

    <!-- Col 2: DM sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <span>Direct Messages</span>
            <form method="post" action="/Auth/Logout" style="display:contents">
                @Html.AntiForgeryToken()
                <button type="submit" class="icon-btn" title="Log Out">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5-5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/>
                    </svg>
                </button>
            </form>
            <button class="icon-btn" id="add-friend-toggle" title="Add Friend">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M15 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm-9-2V7H4v3H1v2h3v3h2v-3h3v-2H6zm9 4c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </svg>
            </button>
        </div>

        <!-- Add friend form -->
        <div id="add-friend-section" class="@(Model.FriendRequestSuccess || Model.FriendRequestError != null ? "" : "hidden")">
            <form method="post" asp-page-handler="SendFriendRequest" class="add-friend-form">
                <input type="text" name="RecipientUsername" placeholder="Enter a username" autocomplete="off" />
                <button type="submit" class="btn-primary btn-sm">Send Request</button>
            </form>
            @if (Model.FriendRequestError != null)
            {
                <div class="form-error">@Model.FriendRequestError</div>
            }
            @if (Model.FriendRequestSuccess)
            {
                <div class="form-success">Friend request sent!</div>
            }
        </div>

        <!-- Pending friend requests -->
        @if (Model.PendingRequests.Any())
        {
            <div class="sidebar-section-header">FRIEND REQUESTS — @Model.PendingRequests.Count</div>
            @foreach (var req in Model.PendingRequests)
            {
                <div class="friend-request-item">
                    <div class="friend-avatar">@req.SenderUsername.Substring(0, 1).ToUpper()</div>
                    <span class="friend-name">@req.SenderUsername</span>
                    <form method="post" asp-page-handler="RespondRequest" style="display:contents">
                        <input type="hidden" name="RequestId" value="@req.Id" />
                        <button name="Accept" value="true" type="submit" class="icon-btn accept-btn" title="Accept">✓</button>
                        <button name="Accept" value="false" type="submit" class="icon-btn reject-btn" title="Reject">✗</button>
                    </form>
                </div>
            }
        }

        <!-- Friends / DM list -->
        @if (Model.Friends.Any())
        {
            <div class="sidebar-section-header">FRIENDS</div>
            @foreach (var friend in Model.Friends)
            {
                var dmUnread = Model.ServerList.DmUnreadCounts.GetValueOrDefault(friend.Id, 0);
                <a href="/App/Index?friendId=@friend.Id"
                   class="dm-item @(Model.ActiveFriendId == friend.Id ? "active" : "")"
                   data-user-id="@friend.Id">
                    <div class="avatar-wrapper">
                        @if (!string.IsNullOrEmpty(friend.AvatarUrl))
                        {
                            <img src="@friend.AvatarUrl" alt="@friend.DisplayOrUsername" class="friend-avatar" />
                        }
                        else
                        {
                            <div class="friend-avatar">@friend.DisplayOrUsername.Substring(0, 1).ToUpper()</div>
                        }
                        <span class="presence-dot @(Model.OnlineFriendIds.Contains(friend.Id) ? "online" : "offline")"></span>
                    </div>
                    <span>@friend.DisplayOrUsername</span>
                    @if (dmUnread > 0)
                    {
                        <span class="notif-badge">@(dmUnread > 9 ? "9+" : dmUnread.ToString())</span>
                    }
                </a>
            }
        }

        @if (!Model.Friends.Any() && !Model.PendingRequests.Any())
        {
            <div class="sidebar-empty">Add friends to start chatting!</div>
        }

        <div class="sidebar-footer">
            <a href="/App/Profile" title="Edit Profile">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </svg>
                Profile
            </a>
        </div>
    </div>

    <div class="sidebar-backdrop"></div>

    <!-- Col 3: DM conversation or welcome -->
    <div class="content-area">
        @{
            var cfg = HttpContext.RequestServices.GetRequiredService<Microsoft.Extensions.Configuration.IConfiguration>();
            var aEmail = cfg["Email:AdminEmail"] ?? "";
            var uEmail = HttpContext.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
            var isAdmin = !string.IsNullOrEmpty(aEmail) && string.Equals(uEmail, aEmail, StringComparison.OrdinalIgnoreCase);
        }
        @if (Model.ActiveFriend != null)
        {
            <div class="content-header">
                <button class="mobile-menu-btn" aria-label="Open menu">&#9776;</button>
                <a href="/App/Profile?userId=@Model.ActiveFriend.Id" class="friend-avatar" title="View Profile">@Model.ActiveFriend.DisplayOrUsername.Substring(0, 1).ToUpper()</a>
                <a href="/App/Profile?userId=@Model.ActiveFriend.Id" class="content-header-friend-name">@Model.ActiveFriend.DisplayOrUsername</a>
                <a href="/App/Wallet" class="orb-balance" title="View Wallet" style="margin-left:auto">
                    <span class="orb-icon"></span>
                    <span id="orb-count-dm">@Model.OrbBalance</span>
                </a>
                <partial name="_NotifDropdown" />
                @if (isAdmin)
                {
                    <a href="/App/Admin/SecurityAdmin" class="icon-btn" title="Site Admin" style="font-size:1rem;text-decoration:none">🛡️</a>
                }
            </div>
            <div id="messages" class="messages-container">
                @{
                    bool? lastDmIsMine = null;
                    DateTime? lastDmTime = null;
                }
                @foreach (var msg in Model.DmMessages)
                {
                    var dmGrouped = lastDmIsMine == msg.IsMine && lastDmTime.HasValue && (msg.SentAt - lastDmTime.Value).TotalMinutes < 5;
                    lastDmIsMine = msg.IsMine;
                    lastDmTime = msg.SentAt;
                    <div class="message @(msg.IsMine ? "mine" : "theirs") @(dmGrouped ? "message-grouped" : "")">
                        @{
                            var dmAvatarUrl = msg.IsMine ? Model.CurrentUserAvatarUrl : Model.ActiveFriend.AvatarUrl;
                            var dmDisplayName = msg.IsMine ? "You" : Model.ActiveFriend.DisplayOrUsername;
                        }
                        @{
                            var dmUserId = msg.IsMine ? User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value : Model.ActiveFriend.Id.ToString();
                        }
                        <a href="/App/Profile?userId=@dmUserId" class="message-avatar-link">
                            @if (!string.IsNullOrEmpty(dmAvatarUrl))
                            {
                                <img src="@dmAvatarUrl" alt="@dmDisplayName" class="message-avatar" />
                            }
                            else
                            {
                                <div class="message-avatar message-avatar-fallback">@dmDisplayName.Substring(0, 1).ToUpper()</div>
                            }
                        </a>
                        <div class="message-author">@dmDisplayName <span class="message-time" data-time="@msg.SentAt.ToString("o")"></span></div>
                        <div class="message-content">@msg.Content</div>
                    </div>
                }
            </div>
            <div id="typing-indicator" class="typing-indicator"></div>
            <div class="message-input-area">
                <form id="dm-form">
                    <input id="dm-input" type="text" placeholder="Message @Model.ActiveFriend.DisplayOrUsername..." autocomplete="off" />
                    <button type="submit">Send</button>
                </form>
            </div>
        }
        else
        {
            <div class="content-header">
                <button class="mobile-menu-btn" aria-label="Open menu">&#9776;</button>
                <span>Home</span>
                <a href="/App/Wallet" class="orb-balance" title="View Wallet" style="margin-left:auto">
                    <span class="orb-icon"></span>
                    <span id="orb-count-home">@Model.OrbBalance</span>
                </a>
                <partial name="_NotifDropdown" />
                @if (isAdmin)
                {
                    <a href="/App/Admin/SecurityAdmin" class="icon-btn" title="Site Admin" style="font-size:1rem;text-decoration:none">🛡️</a>
                }
            </div>
            <div class="welcome-screen">
                @{
                    var onlineFriends = Model.Friends.Where(f => Model.OnlineFriendIds.Contains(f.Id)).ToList();
                    var inviteLink = $"https://torvex.app/Auth/Register?ref={Model.ReferralLink}";
                    var inviteMsg = $"Yo I made a group on Torvex\u2014join up so we can try it\n{inviteLink}";
                }

                <!-- 1. PRIMARY BLOCK — only shown until 5 friends -->
                @if (Model.Friends.Count < 5)
                {
                <div class="welcome-invite-block">
                    <div class="welcome-icon">👋</div>
                    <h2>Your group is empty</h2>
                    <p class="welcome-subtext">Invite your friends to start chatting, talking, and playing together.</p>
                    <button id="copy-invite-link-btn" class="btn-primary welcome-cta-main" data-copy="@inviteLink">
                        Copy invite link
                    </button>
                    <button id="copy-invite-msg-btn" class="btn-secondary welcome-cta-secondary" data-copy="@inviteMsg">
                        Copy invite message
                    </button>
                    <span class="welcome-helper-text">Works best with 2–3 people</span>
                </div>
                }

                <!-- 2. INVITE MESSAGE (visible preview) -->
                <div class="invite-message-preview">
                    <div class="invite-msg-body">
                        <span>Yo I made a group on Torvex—join up so we can try it</span>
                        <span class="invite-msg-url">@inviteLink</span>
                    </div>
                    <button id="copy-msg-preview-btn" class="btn-secondary btn-sm" data-copy="@inviteMsg">
                        Copy message
                    </button>
                </div>

                <!-- 3. SOCIAL STATE -->
                <div class="social-state-bar">
                    <span class="social-state-label">Waiting for your friends…</span>
                    <span class="social-state-count">@Model.Friends.Count / 3 joined</span>
                </div>

                <!-- Online friends (if any) -->
                @if (onlineFriends.Any())
                {
                    <div class="online-friends-section">
                        <h3>Online Now — @onlineFriends.Count</h3>
                        <div class="online-friends-grid">
                            @foreach (var friend in onlineFriends)
                            {
                                <a href="/App/Index?friendId=@friend.Id" class="online-friend-card">
                                    <div class="avatar-wrapper">
                                        @if (!string.IsNullOrEmpty(friend.AvatarUrl))
                                        {
                                            <img src="@friend.AvatarUrl" alt="@friend.DisplayOrUsername" class="friend-avatar" />
                                        }
                                        else
                                        {
                                            <div class="friend-avatar">@friend.DisplayOrUsername.Substring(0, 1).ToUpper()</div>
                                        }
                                        <span class="presence-dot online"></span>
                                    </div>
                                    <span>@friend.DisplayOrUsername</span>
                                </a>
                            }
                        </div>
                    </div>
                }

                <!-- 4. ORBS (demoted) -->
                <div class="orb-claim-section">
                    <div class="orb-balance-display">
                        <span class="orb-icon-lg"></span>
                        <span class="orb-balance-amount" id="orb-balance-home">@Model.OrbBalance</span>
                        <span class="orb-balance-label">Orbs</span>
                    </div>
                    <div class="streak-display">
                        <span>&#x1F525; @Model.CurrentStreak day streak</span>
                    </div>
                    <button id="claim-daily-btn" class="btn-primary btn-daily-claim @(Model.ClaimedToday ? "claimed" : "")"
                            @(Model.ClaimedToday ? "disabled" : "")>
                        @(Model.ClaimedToday ? "Come back tomorrow to keep your streak alive" : "Claim daily reward")
                    </button>
                    <p class="orb-social-hint">Earn more by staying active with your group</p>
                    <div class="orb-links">
                        <a href="/App/OrbShop" class="btn-secondary btn-sm">Orb Shop</a>
                        <a href="/App/Wallet" class="btn-secondary btn-sm">Wallet</a>
                        <a href="/App/Badges" class="btn-secondary btn-sm">Badges</a>
                        <a href="/App/FeatureRequests" class="btn-secondary btn-sm">Feature Requests</a>
                    </div>
                </div>

                <!-- 5. SECONDARY ACTIONS -->
                <div class="welcome-secondary-actions">
                    <p class="welcome-secondary-label">Or find friends on Torvex</p>
                    <button id="add-friend-cta" class="btn-secondary welcome-add-friend-btn">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M15 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm-9-2V7H4v3H1v2h3v3h2v-3h3v-2H6zm9 4c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                        </svg>
                        Add Friends
                    </button>
                </div>

                <!-- 6. WHAT HAPPENS NEXT -->
                <div class="what-happens-next">
                    <h3>What happens next</h3>
                    <ol class="next-steps">
                        <li>Invite your friends</li>
                        <li>They join instantly</li>
                        <li>Start hanging out</li>
                    </ol>
                </div>

            </div>
        }
    </div>

</div>

@section Scripts {
    @if (Model.ActiveFriend != null)
    {
        <script>
            const recipientId = '@Model.ActiveFriend.Id';
            const recipientName = '@Model.ActiveFriend.DisplayOrUsername';
            const currentUserId = '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value';
            const currentUserAvatarUrl = '@(Model.CurrentUserAvatarUrl ?? "")';
            const recipientAvatarUrl = '@(Model.ActiveFriend.AvatarUrl ?? "")';
        </script>
        <script src="~/js/chat.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                // Format DM message timestamps using browser locale (12/24-hour based on user's system)
                document.querySelectorAll('.message-time[data-time]').forEach(el => {
                    el.textContent = ' \u2014 ' + new Date(el.dataset.time).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                });
                // Set grouped-time data attribute for DM grouped messages
                document.querySelectorAll('.message.message-grouped[data-sent]').forEach(el => {
                    el.dataset.groupedTime = new Date(el.dataset.sent).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                });
                if (typeof window.applyEmojiRendering === 'function') window.applyEmojiRendering();
            });
        </script>
    }
    @if (Model.ActiveFriend == null)
    {
        <script>
            // Presence updates on home page (no active DM)
            const _presenceToken = document.querySelector('meta[name="jwt"]')?.content;
            const _presenceConn = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/chat", { accessTokenFactory: () => _presenceToken })
                .withAutomaticReconnect()
                .build();

            _presenceConn.on("UserOnline", (userId) => {
                const item = document.querySelector(`[data-user-id="${userId}"]`);
                if (item) {
                    const dot = item.querySelector('.presence-dot');
                    if (dot) { dot.classList.remove('offline'); dot.classList.add('online'); }
                }
            });

            _presenceConn.on("UserOffline", (userId) => {
                const item = document.querySelector(`[data-user-id="${userId}"]`);
                if (item) {
                    const dot = item.querySelector('.presence-dot');
                    if (dot) { dot.classList.remove('online'); dot.classList.add('offline'); }
                }
            });

            _presenceConn.on("ReceiveNotification", (notif) => {
                if (typeof window._notifDropdownOnNotification === 'function') window._notifDropdownOnNotification();
            });

            _presenceConn.start().catch(() => {});
        </script>
    }
    <script>
        const toggle = document.getElementById('add-friend-toggle');
        const section = document.getElementById('add-friend-section');
        toggle.addEventListener('click', () => section.classList.toggle('hidden'));

        // "Add Friends" secondary CTA on welcome screen
        const addFriendCta = document.getElementById('add-friend-cta');
        if (addFriendCta) {
            addFriendCta.addEventListener('click', () => {
                section.classList.remove('hidden');
                const input = section.querySelector('input[name="RecipientUsername"]');
                if (input) input.focus();
            });
        }

        // Copy-to-clipboard helper
        function copyText(text, btn, original) {
            navigator.clipboard.writeText(text).then(() => {
                btn.textContent = 'Copied!';
                setTimeout(() => btn.textContent = original, 2000);
            }).catch(() => {
                btn.textContent = 'Failed';
                setTimeout(() => btn.textContent = original, 2000);
            });
        }

        // Wire up all copy buttons via data-copy attribute
        document.querySelectorAll('[data-copy]').forEach(btn => {
            btn.addEventListener('click', () => copyText(btn.dataset.copy, btn, btn.textContent.trim()));
        });

        // Daily claim
        const claimBtn = document.getElementById('claim-daily-btn');
        if (claimBtn && !claimBtn.disabled) {
            claimBtn.addEventListener('click', async () => {
                claimBtn.disabled = true;
                claimBtn.textContent = 'Claiming...';
                try {
                    const resp = await fetch('/api/orbs/daily-claim', { method: 'POST' });
                    if (resp.ok) {
                        const data = await resp.json();
                        claimBtn.textContent = `+${data.orbsAwarded} Orbs!`;
                        claimBtn.classList.add('claimed');
                        document.getElementById('orb-balance-home').textContent = data.newBalance;
                        document.querySelector('.streak-display span').innerHTML = `&#x1F525; ${data.currentStreak} day streak`;
                    } else {
                        const err = await resp.json();
                        claimBtn.textContent = err.error || 'Come back tomorrow to keep your streak alive';
                        claimBtn.classList.add('claimed');
                    }
                } catch {
                    claimBtn.textContent = 'Error — try again';
                    claimBtn.disabled = false;
                }
            });
        }
    </script>
}
