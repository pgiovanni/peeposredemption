@page
@model peeposredemption.API.Pages.App.ProfileModel
@{
    ViewData["Title"] = Model.IsOwnProfile ? "Edit Profile" : Model.DisplayName ?? Model.Username;
}

<div class="app-shell">

    <partial name="_ServerList" model="Model.ServerList" />

    <div class="sidebar">
        <div class="sidebar-header">@(Model.IsOwnProfile ? "Edit Profile" : "Profile")</div>
        <a href="/App/Index" class="channel-item">Back to Messages</a>
        @if (Model.IsOwnProfile)
        {
            <a href="/App/Wallet" class="channel-item">Wallet</a>
            <a href="/App/Badges" class="channel-item">Badges</a>
            <a href="/App/OrbShop" class="channel-item">Orb Shop</a>
        }
        else
        {
            <a href="/App/Index?friendId=@Model.ProfileUserId" class="channel-item">Send Message</a>
            <a href="/App/Profile" class="channel-item">My Profile</a>
        }
    </div>

    <div class="sidebar-backdrop"></div>

    <div class="content-area">
        <div class="content-header">
            <button class="mobile-menu-btn" aria-label="Open menu">&#9776;</button>
            <span>@(Model.IsOwnProfile ? "Edit Profile" : (Model.DisplayName ?? Model.Username))</span>
        </div>

        <div class="profile-container">

            @if (Model.IsOwnProfile)
            {
                @if (Model.SaveSuccess)
                {
                    <div class="form-success" id="profile-success">Profile updated!</div>
                }
                @if (Model.ErrorMessage != null)
                {
                    <div class="form-error">@Model.ErrorMessage</div>
                }
            }

            <!-- Profile Card -->
            <div class="profile-preview-card" style="@(Model.ProfileBackgroundColor != null ? $"background-color:{Model.ProfileBackgroundColor}" : "")">
                <div class="profile-banner" id="banner-preview">
                    @if (Model.BannerUrl != null)
                    {
                        <img src="@Model.BannerUrl" alt="Banner" />
                    }
                    @if (Model.IsOwnProfile)
                    {
                        <label class="profile-upload-overlay" for="bannerFile" title="Change banner">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34a.9959.9959 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                            </svg>
                        </label>
                    }
                </div>
                <div class="profile-avatar-section">
                    <div class="profile-avatar" id="avatar-preview">
                        @if (Model.AvatarUrl != null)
                        {
                            <img src="@Model.AvatarUrl" alt="Avatar" />
                        }
                        else
                        {
                            <span class="profile-avatar-initial">@Model.Username.Substring(0, 1).ToUpper()</span>
                        }
                        @if (Model.IsOwnProfile)
                        {
                            <label class="profile-avatar-upload" for="avatarFile" title="Change avatar">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34a.9959.9959 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                                </svg>
                            </label>
                        }
                    </div>
                    <div class="profile-preview-info">
                        <span class="profile-preview-displayname" id="preview-displayname">@(Model.DisplayName ?? Model.Username)</span>
                        <span class="profile-preview-username">@@@Model.Username</span>
                        @if (Model.Pronouns != null)
                        {
                            <span class="profile-preview-pronouns" id="preview-pronouns">@Model.Pronouns</span>
                        }
                    </div>
                </div>
                @if (Model.Bio != null)
                {
                    <div class="profile-preview-bio" id="preview-bio">@Model.Bio</div>
                }
            </div>

            <!-- Public Profile: Member Since + Badges -->
            @if (!Model.IsOwnProfile)
            {
                <div class="profile-section">
                    <div class="profile-section-label">MEMBER SINCE</div>
                    <div class="profile-section-value">@Model.MemberSince.ToString("MMMM d, yyyy")</div>
                </div>
            }

            @if (Model.Badges.Any())
            {
                <div class="profile-section">
                    <div class="profile-section-label">BADGES</div>
                    <div class="profile-badges-grid">
                        @foreach (var badge in Model.Badges)
                        {
                            <div class="profile-badge" title="@badge.Name — @badge.Description">
                                <span class="profile-badge-icon">@badge.Icon</span>
                                <span class="profile-badge-name">@badge.Name</span>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (!Model.IsOwnProfile)
            {
                <!-- Action buttons for public profile -->
                <div class="profile-actions">
                    <a href="/App/Index?friendId=@Model.ProfileUserId" class="btn-primary">Send Message</a>
                </div>
            }

            @if (Model.IsOwnProfile)
            {
                <!-- Edit Form (own profile only) -->
                <form method="post" enctype="multipart/form-data" class="profile-form">
                    <input type="file" id="avatarFile" name="avatarFile" accept="image/png,image/jpeg,image/webp,image/gif"
                           class="hidden" />
                    <input type="file" id="bannerFile" name="bannerFile" accept="image/png,image/jpeg,image/webp,image/gif"
                           class="hidden" />

                    <div class="form-group">
                        <label>Username</label>
                        <input type="text" value="@Model.Username" disabled />
                        <span class="form-hint">This is your unique handle used for friend requests.</span>
                    </div>

                    <div class="form-group">
                        <label>Display Name</label>
                        <input type="text" name="displayName" value="@Model.DisplayName" placeholder="@Model.Username"
                               maxlength="32" id="displayNameInput" />
                        <span class="form-hint">This is how others will see you in chat.</span>
                    </div>

                    <div class="form-group">
                        <label>Bio</label>
                        <textarea name="bio" maxlength="200" rows="3" placeholder="Tell us about yourself..."
                                  id="bioInput">@Model.Bio</textarea>
                        <span class="form-hint"><span id="bio-count">@(Model.Bio?.Length ?? 0)</span>/200</span>
                    </div>

                    <div class="form-group">
                        <label>Pronouns</label>
                        <input type="text" name="pronouns" value="@Model.Pronouns" placeholder="e.g. he/him, she/her, they/them"
                               maxlength="30" id="pronounsInput" />
                    </div>

                    <div class="form-group">
                        <label>Profile Background Color</label>
                        <div class="profile-color-picker">
                            <input type="color" name="profileBackgroundColor"
                                   value="@(Model.ProfileBackgroundColor ?? "#2b2d31")"
                                   id="bgColorInput" />
                            <span class="profile-color-hex" id="bgColorHex">@(Model.ProfileBackgroundColor ?? "#2b2d31")</span>
                            <button type="button" class="btn-cancel btn-sm" id="resetColorBtn">Reset</button>
                        </div>
                    </div>

                    <div class="profile-form-actions">
                        <a href="/App/Index" class="btn-cancel">Cancel</a>
                        <button type="submit" class="btn-primary">Save Changes</button>
                    </div>
                </form>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
@if (Model.IsOwnProfile)
{
    @:// Avatar preview
    @:document.getElementById('avatarFile').addEventListener('change', function(e) {
    @:    const file = e.target.files[0];
    @:    if (!file) return;
    @:    if (file.size > 15 * 1024 * 1024) { alert('Avatar must be under 15MB.'); e.target.value = ''; return; }
    @:    const preview = document.getElementById('avatar-preview');
    @:    const img = preview.querySelector('img') || document.createElement('img');
    @:    img.src = URL.createObjectURL(file);
    @:    img.alt = 'Avatar';
    @:    const initial = preview.querySelector('.profile-avatar-initial');
    @:    if (initial) initial.style.display = 'none';
    @:    if (!preview.querySelector('img')) preview.insertBefore(img, preview.firstChild);
    @:});
    @:
    @:// Banner preview
    @:document.getElementById('bannerFile').addEventListener('change', function(e) {
    @:    const file = e.target.files[0];
    @:    if (!file) return;
    @:    if (file.size > 15 * 1024 * 1024) { alert('Banner must be under 15MB.'); e.target.value = ''; return; }
    @:    const preview = document.getElementById('banner-preview');
    @:    const img = preview.querySelector('img') || document.createElement('img');
    @:    img.src = URL.createObjectURL(file);
    @:    img.alt = 'Banner';
    @:    if (!preview.querySelector('img')) preview.insertBefore(img, preview.firstChild);
    @:});
    @:
    @:// Bio counter
    @:const bioInput = document.getElementById('bioInput');
    @:const bioCount = document.getElementById('bio-count');
    @:bioInput.addEventListener('input', () => { bioCount.textContent = bioInput.value.length; });
    @:
    @:// Live preview: display name
    @:document.getElementById('displayNameInput').addEventListener('input', function() {
    @:    document.getElementById('preview-displayname').textContent = this.value || '@Model.Username';
    @:});
    @:
    @:// Live preview: bio
    @:bioInput.addEventListener('input', function() {
    @:    let preview = document.getElementById('preview-bio');
    @:    if (!preview) {
    @:        preview = document.createElement('div');
    @:        preview.className = 'profile-preview-bio';
    @:        preview.id = 'preview-bio';
    @:        document.querySelector('.profile-preview-card').appendChild(preview);
    @:    }
    @:    preview.textContent = this.value;
    @:    preview.style.display = this.value ? '' : 'none';
    @:});
    @:
    @:// Live preview: pronouns
    @:document.getElementById('pronounsInput').addEventListener('input', function() {
    @:    let preview = document.getElementById('preview-pronouns');
    @:    if (!preview) {
    @:        preview = document.createElement('span');
    @:        preview.className = 'profile-preview-pronouns';
    @:        preview.id = 'preview-pronouns';
    @:        document.querySelector('.profile-preview-info').appendChild(preview);
    @:    }
    @:    preview.textContent = this.value;
    @:    preview.style.display = this.value ? '' : 'none';
    @:});
    @:
    @:// Color picker
    @:const bgColorInput = document.getElementById('bgColorInput');
    @:const bgColorHex = document.getElementById('bgColorHex');
    @:bgColorInput.addEventListener('input', function() {
    @:    bgColorHex.textContent = this.value;
    @:    document.querySelector('.profile-preview-card').style.backgroundColor = this.value;
    @:});
    @:document.getElementById('resetColorBtn').addEventListener('click', function() {
    @:    bgColorInput.value = '#2b2d31';
    @:    bgColorHex.textContent = '#2b2d31';
    @:    document.querySelector('.profile-preview-card').style.backgroundColor = '';
    @:});
    @:
    @:// Auto-hide success message
    @:const successEl = document.getElementById('profile-success');
    @:if (successEl) setTimeout(() => successEl.style.display = 'none', 3000);
}
</script>
}
