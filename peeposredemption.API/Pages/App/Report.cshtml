@page
@model peeposredemption.API.Pages.App.ReportModel
@{
    ViewData["Title"] = "Report / Support";
}

<div class="app-shell">
    <partial name="_ServerList" model="Model.ServerList" />

    <div class="sidebar">
        <div class="sidebar-header">
            <span>Support</span>
        </div>
        <a href="/App/Index" class="dm-item">&#x2190; Back to Home</a>
        <a href="/App/Profile" class="dm-item">Profile</a>
        <a href="/App/Wallet" class="dm-item">Wallet</a>
    </div>

    <div class="sidebar-backdrop"></div>

    <div class="content-area settings-page">
        <div class="content-header">
            <button class="mobile-menu-btn" aria-label="Open menu">&#9776;</button>
            <span>Report / Support</span>
            <a href="/App/Wallet" class="orb-balance" title="View Wallet" style="margin-left:auto">
                <span class="orb-icon"></span>
                <span>@Model.OrbBalance</span>
            </a>
        </div>

        <div class="settings-body">
            <!-- Submit form -->
            <div class="settings-section">
                <div class="settings-heading">Submit a Support Ticket</div>
                <p style="color:#b5bac1;font-size:13px;margin-bottom:12px">
                    Need help or want to report something? Fill out the form below and we'll get back to you.
                </p>

                @if (Model.SubmitSuccess)
                {
                    <div class="form-success" style="margin-bottom:12px">Your support ticket has been submitted! We'll review it shortly.</div>
                }

                <form method="post">
                    <div style="margin-bottom:12px">
                        <label style="display:block;font-size:12px;color:#b5bac1;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.3px">Category</label>
                        <select name="SelectedCategory"
                                style="width:100%;padding:8px 12px;background:#1e1f22;border:1px solid #3f4147;border-radius:4px;color:#f2f3f5;font-size:14px">
                            @foreach (var cat in Enum.GetValues<peeposredemption.Domain.Entities.SupportTicketCategory>())
                            {
                                var label = cat switch
                                {
                                    peeposredemption.Domain.Entities.SupportTicketCategory.BugReport => "Bug Report",
                                    peeposredemption.Domain.Entities.SupportTicketCategory.AccountHelp => "Account Help",
                                    peeposredemption.Domain.Entities.SupportTicketCategory.GeneralQuestion => "General Question",
                                    peeposredemption.Domain.Entities.SupportTicketCategory.TrustSafety => "Trust & Safety",
                                    _ => cat.ToString()
                                };
                                <option value="@cat" selected="@(cat == Model.SelectedCategory)">@label</option>
                            }
                        </select>
                    </div>
                    <div style="margin-bottom:12px">
                        <label style="display:block;font-size:12px;color:#b5bac1;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.3px">Subject</label>
                        <input type="text" name="Subject" value="@Model.Subject" maxlength="150" required
                               placeholder="Brief summary of your issue"
                               style="width:100%;padding:8px 12px;background:#1e1f22;border:1px solid #3f4147;border-radius:4px;color:#f2f3f5;font-size:14px" />
                    </div>
                    <div style="margin-bottom:12px">
                        <label style="display:block;font-size:12px;color:#b5bac1;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.3px">Description</label>
                        <textarea name="Description" maxlength="2000" required rows="5"
                                  placeholder="Describe your issue in detail..."
                                  style="width:100%;padding:8px 12px;background:#1e1f22;border:1px solid #3f4147;border-radius:4px;color:#f2f3f5;font-size:14px;resize:vertical">@Model.Description</textarea>
                    </div>
                    <button type="submit" class="btn-primary">Submit Ticket</button>
                </form>
            </div>

            <!-- Past tickets -->
            @if (Model.MyTickets.Any())
            {
                <div class="settings-section">
                    <div class="settings-heading">Your Tickets</div>
                    <table class="audit-table">
                        <thead>
                            <tr>
                                <th>Category</th>
                                <th>Subject</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ticket in Model.MyTickets)
                            {
                                var statusClass = ticket.Status switch
                                {
                                    peeposredemption.Domain.Entities.SupportTicketStatus.Open => "status-open",
                                    peeposredemption.Domain.Entities.SupportTicketStatus.InProgress => "status-inprogress",
                                    peeposredemption.Domain.Entities.SupportTicketStatus.Resolved => "status-resolved",
                                    peeposredemption.Domain.Entities.SupportTicketStatus.Closed => "status-closed",
                                    _ => ""
                                };
                                var catLabel = ticket.Category switch
                                {
                                    peeposredemption.Domain.Entities.SupportTicketCategory.BugReport => "Bug Report",
                                    peeposredemption.Domain.Entities.SupportTicketCategory.AccountHelp => "Account Help",
                                    peeposredemption.Domain.Entities.SupportTicketCategory.GeneralQuestion => "General Question",
                                    peeposredemption.Domain.Entities.SupportTicketCategory.TrustSafety => "Trust & Safety",
                                    _ => ticket.Category.ToString()
                                };
                                var statusLabel = ticket.Status switch
                                {
                                    peeposredemption.Domain.Entities.SupportTicketStatus.InProgress => "In Progress",
                                    _ => ticket.Status.ToString()
                                };
                                <tr>
                                    <td>@catLabel</td>
                                    <td>@ticket.Subject</td>
                                    <td><span class="ticket-status-badge @statusClass">@statusLabel</span></td>
                                    <td class="audit-time">@ticket.CreatedAt.ToString("MMM dd, yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="settings-section">
                    <div class="settings-heading">Your Tickets</div>
                    <p style="color:#949ba4;font-size:14px">You haven't submitted any support tickets yet.</p>
                </div>
            }
        </div>
    </div>
</div>
