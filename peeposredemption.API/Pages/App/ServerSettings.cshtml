@page
@model peeposredemption.API.Pages.App.ServerSettingsModel
@using peeposredemption.Domain.Entities
@{
    ViewData["Title"] = "Server Settings";
}

<div class="app-shell">
    <div class="sidebar">
        <div class="sidebar-header">
            <a href="javascript:history.back()" class="icon-btn" title="Back">←</a>
            <span>Server Settings</span>
        </div>
    </div>

    <div class="content-area settings-page">

        @if (Model.StatusMessage != null)
        {
            <div class="alert-success">@Model.StatusMessage</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-error">@TempData["Error"]</div>
        }

        <!-- Emojis -->
        <section class="settings-section">
            <h3 class="settings-heading">
                EMOJIS — @Model.Emojis.Count / @Model.EmojiLimit
                @if (Model.ServerStorageTier == StorageTier.Standard)
                {
                    <span class="badge-standard">STANDARD</span>
                }
                else if (Model.ServerStorageTier == StorageTier.Boosted)
                {
                    <span class="badge-boosted">BOOSTED</span>
                }
            </h3>

            @if (Model.Emojis.Any())
            {
                <div class="emoji-gallery">
                    @foreach (var emoji in Model.Emojis)
                    {
                        <div class="emoji-item">
                            <img src="@emoji.ImageUrl" alt="@emoji.Name" class="emoji-preview" />
                            <span class="emoji-name">:@emoji.Name:</span>
                            @if (Model.CurrentUserRole >= ServerRole.Moderator)
                            {
                                <form method="post" asp-page-handler="DeleteEmoji" style="display:inline">
                                    <input type="hidden" name="serverId" value="@Model.ServerId" />
                                    <input type="hidden" name="emojiId" value="@emoji.Id" />
                                    <button type="submit" class="icon-btn emoji-delete-btn" title="Delete emoji">✕</button>
                                </form>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="sidebar-empty">No custom emojis yet.</div>
            }

            @if (Model.CurrentUserRole >= ServerRole.Moderator && Model.Emojis.Count < Model.EmojiLimit)
            {
                <form method="post" asp-page-handler="UploadEmoji" enctype="multipart/form-data" class="emoji-upload-form">
                    <input type="hidden" name="serverId" value="@Model.ServerId" />
                    <input type="text" name="emojiName" placeholder="emoji_name" required pattern="[a-z0-9_]{2,32}"
                           title="2-32 lowercase letters, numbers, or underscores" autocomplete="off" />
                    <input type="file" name="emojiFile" accept="image/png,image/gif,image/webp" required />
                    <button type="submit" class="btn-primary btn-sm">Upload Emoji</button>
                </form>
                <div class="emoji-hint">PNG, GIF, or WebP · Max 256KB · Name: lowercase letters, numbers, underscores</div>
            }
            else if (Model.CurrentUserRole >= ServerRole.Moderator && Model.Emojis.Count >= Model.EmojiLimit)
            {
                <div class="emoji-hint">Emoji limit reached (@Model.EmojiLimit).</div>
            }

            @if (Model.CurrentUserRole == ServerRole.Owner && Model.ServerStorageTier < StorageTier.Boosted)
            {
                <div class="upgrade-options">
                    @if (Model.ServerStorageTier < StorageTier.Standard)
                    {
                        <form method="post" asp-page-handler="BuyBoost" class="boost-form">
                            <input type="hidden" name="serverId" value="@Model.ServerId" />
                            <input type="hidden" name="targetTier" value="@((int)StorageTier.Standard)" />
                            <button type="submit" class="btn-boost btn-boost-standard">⚡ Standard — $1.99 <span class="tier-detail">150 emojis · one-time</span></button>
                        </form>
                    }
                    <form method="post" asp-page-handler="BuyBoost" class="boost-form">
                        <input type="hidden" name="serverId" value="@Model.ServerId" />
                        <input type="hidden" name="targetTier" value="@((int)StorageTier.Boosted)" />
                        <button type="submit" class="btn-boost btn-boost-pro">🚀 Boosted — $4.99 <span class="tier-detail">500 emojis · one-time</span></button>
                    </form>
                </div>
            }
        </section>

        <!-- Members -->
        <section class="settings-section">
            <h3 class="settings-heading">MEMBERS — @Model.Members.Count</h3>
            @foreach (var m in Model.Members)
            {
                <div class="member-row">
                    <div class="friend-avatar">@m.Username.Substring(0, 1).ToUpper()</div>
                    <span class="member-name">@m.Username</span>
                    <span class="member-role role-@m.Role.ToString().ToLower()">@m.Role</span>
                    @if (Model.CurrentUserRole == ServerRole.Owner && m.Role != ServerRole.Owner)
                    {
                        <form method="post" asp-page-handler="Kick" style="display:inline">
                            <input type="hidden" name="serverId" value="@Model.ServerId" />
                            <input type="hidden" name="targetUserId" value="@m.UserId" />
                            <button type="submit" class="btn-danger btn-sm">Kick</button>
                        </form>
                        <form method="post" asp-page-handler="Ban" style="display:inline">
                            <input type="hidden" name="serverId" value="@Model.ServerId" />
                            <input type="hidden" name="targetUserId" value="@m.UserId" />
                            <button type="submit" class="btn-danger btn-sm">Ban</button>
                        </form>
                    }
                </div>
            }
        </section>

        <!-- Audit Log -->
        <section class="settings-section">
            <h3 class="settings-heading">AUDIT LOG</h3>
            @if (!Model.AuditLog.Any())
            {
                <div class="sidebar-empty">No moderation actions yet.</div>
            }
            else
            {
                <table class="audit-table">
                    <thead>
                        <tr>
                            <th>When</th>
                            <th>Moderator</th>
                            <th>Action</th>
                            <th>Target</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Model.AuditLog)
                        {
                            <tr>
                                <td class="audit-time">@entry.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@entry.Moderator.Username</td>
                                <td class="audit-action">@entry.Action</td>
                                <td>@entry.TargetUser.Username</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </section>

    </div>
</div>
