@page
@model peeposredemption.API.Pages.App.ServerSettingsModel
@using peeposredemption.Domain.Entities
@{
    ViewData["Title"] = "Server Settings";
}

<div class="app-shell">
    <div class="sidebar">
        <div class="sidebar-header">
            <span>@(Model.ServerName ?? "Server") Settings</span>
        </div>
        <a href="javascript:history.back()" class="channel-item">&larr; Back to Server</a>
        <div class="sidebar-section-header">SETTINGS</div>
        <a href="#members" class="channel-item settings-nav active" data-tab="members">Members</a>
        <a href="#banned" class="channel-item settings-nav" data-tab="banned">Banned (@Model.BannedMembers.Count)</a>
        <a href="#emojis" class="channel-item settings-nav" data-tab="emojis">Emojis</a>
        @if (Model.CurrentUserRole == ServerRole.Owner)
        {
            <a href="#server" class="channel-item settings-nav" data-tab="server">Server</a>
            <a href="#security" class="channel-item settings-nav" data-tab="security">Security</a>
        }
        <a href="#audit" class="channel-item settings-nav" data-tab="audit">Audit Log</a>
    </div>

    <div class="sidebar-backdrop"></div>

    <div class="content-area settings-page">
        <div class="content-header">
            <button class="mobile-menu-btn" aria-label="Open menu">&#9776;</button>
            <span>Server Settings</span>
        </div>

        <div class="settings-body">
            @if (Model.StatusMessage != null)
            {
                <div class="alert-success">@Model.StatusMessage</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert-error">@TempData["Error"]</div>
            }

            <!-- Members Tab (default) -->
            <div class="settings-tab active" id="tab-members">
                <section class="settings-section">
                    <h3 class="settings-heading">MEMBERS — @Model.Members.Count</h3>
                    @foreach (var m in Model.Members)
                    {
                        <div class="member-row">
                            <div class="friend-avatar">@m.Username.Substring(0, 1).ToUpper()</div>
                            <span class="member-name">@m.Username</span>
                            <span class="member-role role-@m.Role.ToString().ToLower()">@m.Role</span>
                            @if (Model.CurrentUserRole == ServerRole.Owner && m.Role != ServerRole.Owner)
                            {
                                <form method="post" asp-page-handler="Kick" style="display:inline">
                                    <input type="hidden" name="serverId" value="@Model.ServerId" />
                                    <input type="hidden" name="targetUserId" value="@m.UserId" />
                                    <button type="submit" class="btn-danger btn-sm">Kick</button>
                                </form>
                                <form method="post" asp-page-handler="Ban" style="display:inline">
                                    <input type="hidden" name="serverId" value="@Model.ServerId" />
                                    <input type="hidden" name="targetUserId" value="@m.UserId" />
                                    <button type="submit" class="btn-danger btn-sm">Ban</button>
                                </form>
                            }
                        </div>
                    }
                </section>
            </div>

            <!-- Banned Members Tab -->
            <div class="settings-tab" id="tab-banned">
                <section class="settings-section">
                    <h3 class="settings-heading">BANNED MEMBERS — @Model.BannedMembers.Count</h3>
                    @if (Model.BannedMembers.Any())
                    {
                        @foreach (var ban in Model.BannedMembers)
                        {
                            <div class="member-row">
                                <div class="friend-avatar">@ban.User.Username.Substring(0, 1).ToUpper()</div>
                                <span class="member-name">@ban.User.Username</span>
                                <span class="member-role" style="color:#72767d;font-size:12px">
                                    Banned <span class="local-time" data-utc="@ban.BannedAt.ToString("o")"></span>
                                    by @ban.BannedBy.Username
                                </span>
                                @if (Model.CurrentUserRole >= ServerRole.Admin)
                                {
                                    <form method="post" asp-page-handler="Unban" style="display:inline;margin-left:auto">
                                        <input type="hidden" name="serverId" value="@Model.ServerId" />
                                        <input type="hidden" name="targetUserId" value="@ban.UserId" />
                                        <button type="submit" class="btn-primary btn-sm">Unban</button>
                                    </form>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="sidebar-empty">No banned members.</div>
                    }
                </section>
            </div>

            <!-- Emojis Tab -->
            <div class="settings-tab" id="tab-emojis">
                <section class="settings-section">
                    <h3 class="settings-heading">
                        EMOJIS — @Model.Emojis.Count / @Model.EmojiLimit
                        @if (Model.ServerStorageTier == StorageTier.Standard)
                        {
                            <span class="badge-standard">STANDARD</span>
                        }
                        else if (Model.ServerStorageTier == StorageTier.Boosted)
                        {
                            <span class="badge-boosted">BOOSTED</span>
                        }
                    </h3>

                    @if (Model.Emojis.Any())
                    {
                        <div class="emoji-gallery">
                            @foreach (var emoji in Model.Emojis)
                            {
                                <div class="emoji-item">
                                    <img src="@emoji.ImageUrl" alt="@emoji.Name" class="emoji-preview" />
                                    <span class="emoji-name">:@emoji.Name:</span>
                                    @if (Model.CurrentUserRole >= ServerRole.Moderator)
                                    {
                                        <form method="post" asp-page-handler="DeleteEmoji" style="display:inline">
                                            <input type="hidden" name="serverId" value="@Model.ServerId" />
                                            <input type="hidden" name="emojiId" value="@emoji.Id" />
                                            <button type="submit" class="icon-btn emoji-delete-btn" title="Delete emoji">✕</button>
                                        </form>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="sidebar-empty">No custom emojis yet.</div>
                    }

                    @if (Model.CurrentUserRole >= ServerRole.Moderator && Model.Emojis.Count < Model.EmojiLimit)
                    {
                        <form method="post" asp-page-handler="UploadEmoji" enctype="multipart/form-data" class="emoji-upload-form">
                            <input type="hidden" name="serverId" value="@Model.ServerId" />
                            <input type="text" name="emojiName" placeholder="emoji_name" required pattern="[a-z0-9_]{2,32}"
                                   title="2-32 lowercase letters, numbers, or underscores" autocomplete="off" />
                            <input type="file" name="emojiFile" accept="image/png,image/gif,image/webp" required />
                            <button type="submit" class="btn-primary btn-sm">Upload Emoji</button>
                        </form>
                        <div class="emoji-hint">PNG, GIF, or WebP · Max 256KB · Name: lowercase letters, numbers, underscores</div>
                    }
                    else if (Model.CurrentUserRole >= ServerRole.Moderator && Model.Emojis.Count >= Model.EmojiLimit)
                    {
                        <div class="emoji-hint">Emoji limit reached (@Model.EmojiLimit).</div>
                    }

                    @if (Model.ServerStorageTier < StorageTier.Boosted)
                    {
                        <div class="upgrade-options">
                            @if (Model.ServerStorageTier < StorageTier.Standard)
                            {
                                <form method="post" asp-page-handler="BuyBoost" class="boost-form">
                                    <input type="hidden" name="serverId" value="@Model.ServerId" />
                                    <input type="hidden" name="targetTier" value="@((int)StorageTier.Standard)" />
                                    <button type="submit" class="btn-boost btn-boost-standard">⚡ Standard — $1.99 <span class="tier-detail">150 emojis · one-time</span></button>
                                </form>
                            }
                            <form method="post" asp-page-handler="BuyBoost" class="boost-form">
                                <input type="hidden" name="serverId" value="@Model.ServerId" />
                                <input type="hidden" name="targetTier" value="@((int)StorageTier.Boosted)" />
                                <button type="submit" class="btn-boost btn-boost-pro">🚀 Boosted — $4.99 <span class="tier-detail">500 emojis · one-time</span></button>
                            </form>
                        </div>
                    }
                </section>
            </div>

            <!-- Server Tab (Owner only) -->
            @if (Model.CurrentUserRole == ServerRole.Owner)
            {
                <div class="settings-tab" id="tab-server">
                    <section class="settings-section">
                        <h3 class="settings-heading">SERVER ICON</h3>
                        <div class="server-icon-preview">
                            @if (Model.ServerIconUrl != null)
                            {
                                <img src="@Model.ServerIconUrl" alt="Server icon" class="server-icon-img" id="icon-preview-img" />
                            }
                            else
                            {
                                <div class="server-icon-fallback" id="icon-preview-fallback">@Model.ServerName?.Substring(0, 1).ToUpper()</div>
                            }
                        </div>
                        <form method="post" asp-page-handler="UploadIcon" enctype="multipart/form-data" class="server-icon-upload-form">
                            <input type="hidden" name="serverId" value="@Model.ServerId" />
                            <input type="file" name="iconFile" accept="image/png,image/jpeg,image/webp,image/gif" required id="iconFileInput" />
                            <button type="submit" class="btn-primary btn-sm">Upload Icon</button>
                        </form>
                        <div class="emoji-hint">PNG, JPEG, WebP, or GIF · Max 15MB · Recommended: 128x128</div>
                    </section>
                    <section class="settings-section" style="margin-top:24px">
                        <h3 class="settings-heading">VISIBILITY</h3>
                        <div style="display:flex;align-items:center;gap:16px;margin-bottom:8px">
                            <span style="color:#dcddde">Private server</span>
                            <label class="toggle-switch" style="margin:0">
                                <input type="checkbox" id="private-server-toggle" @(Model.IsPrivate ? "checked" : "") />
                                <span class="toggle-slider"></span>
                            </label>
                            <span id="private-server-status" style="color:#72767d;font-size:13px">
                                @(Model.IsPrivate ? "On — invite prompts are hidden" : "Off — invite prompts show until 5 members")
                            </span>
                        </div>
                    </section>
                </div>
            }

            <!-- Security Tab (Owner only) -->
            @if (Model.CurrentUserRole == ServerRole.Owner)
            {
            <div class="settings-tab" id="tab-security">
                <section class="settings-section">
                    <h3 class="settings-heading">MODERATION SECURITY</h3>
                    <div style="display:flex;align-items:center;gap:16px;margin-bottom:8px">
                        <span style="color:#dcddde">Require MFA for moderators</span>
                        <label class="toggle-switch" style="margin:0">
                            <input type="checkbox" id="require-mfa-toggle" @(Model.RequireMfaForModerators ? "checked" : "") />
                            <span class="toggle-slider"></span>
                        </label>
                        <span id="require-mfa-status" style="color:#72767d;font-size:13px">
                            @(Model.RequireMfaForModerators ? "Enabled — mods without MFA cannot take moderation actions" : "Disabled")
                        </span>
                    </div>
                </section>

                <section class="settings-section" style="margin-top:24px">
                    <h3 class="settings-heading">ALT DETECTION</h3>
                    <p style="color:#72767d;font-size:13px;margin-bottom:12px">Confidence-scored alt account pairs within this server (score ≥ 40).</p>
                    <button id="load-server-alt-suspects" class="btn btn-sm">Load Alt Suspects</button>
                    <div id="server-alt-suspects-container" style="margin-top:12px"></div>
                </section>
            </div>
            }

            <!-- Audit Log Tab -->
            <div class="settings-tab" id="tab-audit">
                <section class="settings-section">
                    <h3 class="settings-heading">AUDIT LOG</h3>
                    @if (!Model.AuditLog.Any())
                    {
                        <div class="sidebar-empty">No moderation actions yet.</div>
                    }
                    else
                    {
                        <table class="audit-table">
                            <thead>
                                <tr>
                                    <th>When</th>
                                    <th>Moderator</th>
                                    <th>Action</th>
                                    <th>Target</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in Model.AuditLog)
                                {
                                    <tr>
                                        <td class="audit-time">@entry.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@entry.Moderator.Username</td>
                                        <td class="audit-action">@entry.Action</td>
                                        <td>@entry.TargetUser.Username</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </section>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('.settings-nav').forEach(link => {
        link.addEventListener('click', function (e) {
            e.preventDefault();
            const tab = this.dataset.tab;
            document.querySelectorAll('.settings-nav').forEach(n => n.classList.remove('active'));
            this.classList.add('active');
            document.querySelectorAll('.settings-tab').forEach(t => t.classList.remove('active'));
            document.getElementById('tab-' + tab).classList.add('active');
        });
    });

    // Render local times for banned members
    document.querySelectorAll('.local-time').forEach(el => {
        const d = new Date(el.dataset.utc);
        el.textContent = d.toLocaleDateString() + ' ' + d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    });

    // Security tab — MFA toggle
    const mfaToggle = document.getElementById('require-mfa-toggle');
    if (mfaToggle) {
        const jwt = document.querySelector('meta[name="jwt"]')?.content;
        const serverId = '@Model.ServerId';
        mfaToggle.addEventListener('change', async () => {
            const enabled = mfaToggle.checked;
            const res = await fetch('/api/servers/' + serverId + '/require-mfa', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + jwt },
                body: JSON.stringify({ enabled })
            });
            const status = document.getElementById('require-mfa-status');
            if (res.ok) {
                status.textContent = enabled
                    ? 'Enabled — mods without MFA cannot take moderation actions'
                    : 'Disabled';
                status.style.color = enabled ? '#3ba55c' : '#72767d';
            } else {
                mfaToggle.checked = !enabled;
                status.textContent = 'Failed to update. Try again.';
                status.style.color = '#ed4245';
            }
        });

        // Private server toggle
        const privateToggle = document.getElementById('private-server-toggle');
        if (privateToggle) {
            privateToggle.addEventListener('change', async () => {
                const enabled = privateToggle.checked;
                const res = await fetch('/api/servers/' + serverId + '/private', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + jwt },
                    body: JSON.stringify({ enabled })
                });
                const status = document.getElementById('private-server-status');
                if (res.ok) {
                    status.textContent = enabled ? 'On — invite prompts are hidden' : 'Off — invite prompts show until 5 members';
                    status.style.color = enabled ? '#3ba55c' : '#72767d';
                } else {
                    privateToggle.checked = !enabled;
                    status.textContent = 'Failed to update. Try again.';
                    status.style.color = '#ed4245';
                }
            });
        }

        // Alt detection
        const altBtn = document.getElementById('load-server-alt-suspects');
        if (altBtn) {
            altBtn.addEventListener('click', async () => {
                const container = document.getElementById('server-alt-suspects-container');
                container.innerHTML = '<p style="color:#949ba4">Loading…</p>';
                const res = await fetch('/api/moderation/alt-suspects?serverId=' + serverId, {
                    headers: { 'Authorization': 'Bearer ' + jwt }
                });
                if (!res.ok) { container.innerHTML = '<p style="color:#ed4245">Failed to load.</p>'; return; }
                const pairs = await res.json();
                if (!pairs.length) {
                    container.innerHTML = '<p style="color:#3ba55c">No alt suspects detected in this server.</p>';
                    return;
                }
                let html = '<table class="audit-table" style="width:100%"><thead><tr><th>User A</th><th>User B</th><th>Score</th><th>Signals</th></tr></thead><tbody>';
                pairs.forEach(p => {
                    const scoreColor = p.score >= 80 ? '#ed4245' : p.score >= 60 ? '#faa61a' : '#dcddde';
                    html += `<tr>
                        <td>${p.userAName}</td>
                        <td>${p.userBName}</td>
                        <td style="font-weight:bold;color:${scoreColor}">${p.score}%</td>
                        <td style="font-size:12px;color:#949ba4">${p.matchReasons.join(' · ')}</td>
                    </tr>`;
                });
                html += '</tbody></table>';
                container.innerHTML = html;
            });
        }
    }
</script>
}
