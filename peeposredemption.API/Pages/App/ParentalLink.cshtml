@page
@model peeposredemption.API.Pages.App.ParentalLinkModel
@{
    ViewData["Title"] = "Parent Link";
}

<div class="app-shell">
    <partial name="_ServerList" model="Model.ServerList" />

    <div class="sidebar">
        <div class="sidebar-header">
            <span>Parent Link</span>
        </div>
        <a href="/App/Index" class="dm-item">&#x2190; Back to Home</a>
    </div>

    <div class="sidebar-backdrop"></div>

    <div class="content-area">
        <div class="content-header">
            <button class="mobile-menu-btn" aria-label="Open menu">&#9776;</button>
            <span>Parent Link</span>
        </div>

        <div class="wallet-container">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="wallet-empty" style="color: #f44; border: 1px solid #f44; padding: 12px; border-radius: 8px; margin-bottom: 16px;">@Model.ErrorMessage</div>
            }
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="wallet-success" style="margin-bottom: 16px;">@Model.SuccessMessage</div>
            }

            @if (!Model.IsMinor)
            {
                <div class="wallet-empty">
                    This page is for minor accounts (ages 13-17). Your account is not flagged as a minor.
                    <br /><br />
                    If you are a parent, go to <a href="/App/ParentalDashboard">Parental Dashboard</a> to manage your child's account.
                </div>
            }
            else if (Model.ActiveLink != null)
            {
                <div class="wallet-summary">
                    <div class="wallet-balance-card">
                        <div class="wallet-balance-label">Linked Parent</div>
                        <div class="wallet-balance-value">@Model.ActiveLink.ParentUsername</div>
                    </div>
                </div>

                <h3 class="wallet-section-title">Active Controls</h3>
                <div class="transaction-table">
                    <div class="transaction-row">
                        <span class="transaction-type">Account Frozen</span>
                        <span class="transaction-amount">@(Model.ActiveLink.AccountFrozen ? "Yes" : "No")</span>
                    </div>
                    <div class="transaction-row">
                        <span class="transaction-type">DMs Friends Only</span>
                        <span class="transaction-amount">@(Model.ActiveLink.DmFriendsOnly ? "Yes" : "No")</span>
                    </div>
                </div>

                <form method="post" asp-page-handler="Revoke" style="margin-top: 16px;">
                    <input type="hidden" name="linkId" value="@Model.ActiveLink.LinkId" />
                    <button type="submit" class="btn-danger" onclick="return confirm('Are you sure you want to revoke this parental link? All restrictions will be removed.');">Revoke Link</button>
                </form>
            }
            else
            {
                <div class="wallet-empty">
                    No parent is currently linked to your account. Generate a code below and share it with your parent/guardian so they can connect.
                </div>

                @if (!string.IsNullOrEmpty(Model.PendingCode))
                {
                    <div class="wallet-balance-card" style="margin-top: 16px; text-align: center;">
                        <div class="wallet-balance-label">Your Link Code</div>
                        <div class="wallet-balance-value" style="font-size: 2rem; letter-spacing: 0.3em;">@Model.PendingCode</div>
                        <div style="font-size: 0.85rem; color: #aaa; margin-top: 8px;">This code expires in 24 hours.</div>
                    </div>
                }

                <form method="post" asp-page-handler="GenerateCode" style="margin-top: 16px;">
                    <button type="submit">Generate Link Code</button>
                </form>
            }
        </div>
    </div>
</div>
