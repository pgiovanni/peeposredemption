@page
@model peeposredemption.API.Pages.IndexModel
@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Torvex — Built for your friend group";
    ViewData["OgTitle"] = "Torvex — Built for your friend group";
    ViewData["Description"] = "A private space to chat, talk, and actually do things together. Real-time messaging, voice channels, a built-in RPG, and rewards — designed for small groups.";
}

<section class="hero">
    <h1>Built for your <span class="hero-accent">friend group.</span></h1>
    <p class="hero-emotional">A better place to hang out.</p>
    <p>Perfect for game nights, small friend groups, and daily hangouts.</p>
    <p>A private space to chat, talk, and actually do things together — without the noise of big servers.</p>
    <div class="hero-micro">For groups of 2–10 people.</div>
    <div class="hero-cta">
        <a href="/Auth/Register" class="btn-large btn-signup">Start your group</a>
        <a href="/Auth/Login" class="btn-large btn-login">Log In</a>
    </div>
</section>

<section class="features">
    <h2>Everything your group needs to hang out</h2>
    <p class="section-subtitle">No clutter. No setup. Just you and your friends.</p>
    <div class="features-grid">
        <div class="feature-card">
            <span class="feature-icon">💬</span>
            <h3>Stay in sync</h3>
            <p>Message your group instantly — no clutter, no distractions.</p>
        </div>
        <div class="feature-card">
            <span class="feature-icon">🎙️</span>
            <h3>Jump into voice anytime</h3>
            <p>Talk with your friends instantly — no setup needed.</p>
        </div>
        <div class="feature-card">
            <span class="feature-icon">🔮</span>
            <h3>Earn while you hang out</h3>
            <p>Get rewards just for being active with your group.</p>
        </div>
        <div class="feature-card">
            <span class="feature-icon">⚔️</span>
            <h3>Play together in chat</h3>
            <p>Fight, trade, and compete — right inside your group.</p>
        </div>
        <div class="feature-card">
            <span class="feature-icon">😎</span>
            <h3>Make it yours</h3>
            <p>Use custom emojis and personalize your group space.</p>
        </div>
        <div class="feature-card">
            <span class="feature-icon">🏆</span>
            <h3>Show off your progress</h3>
            <p>Earn badges and track your activity with your friends.</p>
        </div>
    </div>
</section>

<section class="landing-mid-cta">
    <p>Create your group and invite your friends in seconds.</p>
    <a href="/Auth/Register" class="btn-large btn-signup">Start your group</a>
</section>

<section class="landing-differentiator">
    <h2>Chat is just the start.</h2>
    <p>Your group can play, earn, and interact in real time — without switching apps.</p>
    <div class="differentiator-tagline philosophy-line">Simple to start. Deep when you need it.</div>
</section>

<section class="features" style="padding-top:0">
    <h2>Make your group your own</h2>
    <div class="features-grid" style="max-width:700px;margin:0 auto">
        <div class="feature-card">
            <span class="feature-icon">🎨</span>
            <h3>Customize your space</h3>
            <p>Make your group feel like yours with visuals, styles, and identity.</p>
        </div>
        <div class="feature-card">
            <span class="feature-icon">🔗</span>
            <h3>Invite your friends</h3>
            <p>Bring everyone in with a simple link — no setup, no friction.</p>
        </div>
    </div>
</section>

<section class="landing-how-it-works">
    <h2>Start in under 30 seconds</h2>
    <p class="section-subtitle">No downloads. No setup. Just send a link.</p>
    <div class="steps-grid">
        <div class="step-card">
            <div class="step-num">1</div>
            <h3>Create your group</h3>
            <p>Name it and you're ready.</p>
        </div>
        <div class="step-card">
            <div class="step-num">2</div>
            <h3>Invite your friends</h3>
            <p>Send a link — no installs, no friction.</p>
        </div>
        <div class="step-card">
            <div class="step-num">3</div>
            <h3>Start hanging out</h3>
            <p>Chat, talk, and play — instantly.</p>
        </div>
    </div>
</section>

<section class="landing-depth">
    <h2>Simple at first. Surprisingly deep.</h2>
    <p class="section-subtitle">The more your group uses Torvex, the more it opens up.</p>
    <div class="features-grid">
        <div class="feature-card">
            <span class="feature-icon">📂</span>
            <h3>Organize your space your way</h3>
            <p>Channels, structure, and control when you need it.</p>
        </div>
        <div class="feature-card">
            <span class="feature-icon">💰</span>
            <h3>A full rewards system</h3>
            <p>Earn, spend, and interact through a built-in economy.</p>
        </div>
        <div class="feature-card">
            <span class="feature-icon">📈</span>
            <h3>Progress that actually means something</h3>
            <p>Activity, achievements, and real progression with your group.</p>
        </div>
        <div class="feature-card">
            <span class="feature-icon">🛠️</span>
            <h3>Tools for creators</h3>
            <p>Customize and extend your group experience.</p>
        </div>
    </div>
    <div style="text-align:center;margin-top:24px">
        <a href="/Artists" class="section-link" style="display:inline;margin-right:24px">Create for Torvex &rarr;</a>
        <a href="/Referrals" class="section-link" style="display:inline">Earn by sharing &rarr;</a>
    </div>
</section>

<section class="landing-emotional">
    <p>Your group already exists.<br /><strong>Torvex gives it a place that actually fits.</strong></p>
</section>

<section class="landing-help">
    <h2>Need help?</h2>
    <p class="section-subtitle">Find answers or get support anytime.</p>
    <div class="help-grid">
        <a href="/Help#getting-started" class="help-topic-card">
            <span class="help-topic-icon">🚀</span>
            <h3>Getting Started</h3>
            <p>Create your account, join a group, and start chatting in minutes.</p>
        </a>
        <a href="/Help#chat-servers" class="help-topic-card">
            <span class="help-topic-icon">💬</span>
            <h3>Chat & Servers</h3>
            <p>Channels, DMs, mentions, emojis, GIFs, and everything messaging.</p>
        </a>
        <a href="/Help#orbs-economy" class="help-topic-card">
            <span class="help-topic-icon">🔮</span>
            <h3>Orbs & Economy</h3>
            <p>Earn, spend, and gift orbs. Daily rewards, streaks, and the shop.</p>
        </a>
        <a href="/Help#game" class="help-topic-card">
            <span class="help-topic-icon">⚔️</span>
            <h3>Game Commands</h3>
            <p>Fight monsters, craft items, trade, and climb the leaderboard.</p>
        </a>
    </div>
    <a href="/Help" class="section-link">View all documentation &rarr;</a>
</section>

<section class="landing-support">
    <h2>Get in touch</h2>
    <p class="section-subtitle">Questions, feedback, or issues — we're here to help.</p>
    <div class="support-cards">
        <a href="/App/Report?category=BugReport" class="support-card-landing">
            <span class="support-card-landing-icon">🐛</span>
            <h3>Bug Report</h3>
            <p>Something broken? Let us know.</p>
        </a>
        <a href="/App/Report?category=AccountHelp" class="support-card-landing">
            <span class="support-card-landing-icon">🔑</span>
            <h3>Account Help</h3>
            <p>Locked out or need assistance.</p>
        </a>
        <a href="/App/Report?category=GeneralQuestion" class="support-card-landing">
            <span class="support-card-landing-icon">💬</span>
            <h3>General Question</h3>
            <p>Anything else — we're happy to help.</p>
        </a>
    </div>
    <p class="support-email-line">Need help? <a href="/Support"><strong>Visit our support page</strong></a></p>
    <a href="/Support" class="section-link">More support options &rarr;</a>
    <div style="margin-top:1.5rem;text-align:center">
        <a href="/App/FeatureRequests" class="section-link">Have a feature idea? Submit a request &rarr;</a>
    </div>
</section>

<section class="landing-trust">
    <h2>Trust & Safety</h2>
    <p class="section-subtitle">Your safety is our priority. We take issues seriously and act quickly.</p>
    <a href="/App/Report?category=TrustSafety" class="btn-report-landing">Report an Issue</a>
    <div class="trust-topics">
        <div class="trust-topic">🚫 Harassment</div>
        <div class="trust-topic">👶 Underage users</div>
        <div class="trust-topic">⚠️ Inappropriate content</div>
        <div class="trust-topic">🔒 Threats</div>
    </div>
    <a href="/TrustSafety" class="section-link">Read our full Trust & Safety policy &rarr;</a>
</section>

<section class="landing-final-cta">
    <h2>Start your group today</h2>
    <a href="/Auth/Register" class="btn-large btn-signup">Start your group</a>
    <p class="landing-final-cta-sub">It takes less than a minute.</p>
</section>

<footer class="landing-footer">
    <div class="footer-links">
        <a href="/Privacy">Privacy Policy</a>
        <a href="/TrustSafety">Trust &amp; Safety</a>
        <a href="/Help">Help</a>
        <a href="/Support">Support</a>
        <a href="/Artists">Artists</a>
    </div>
    <p class="footer-copy">&copy; @DateTime.UtcNow.Year Torvex</p>
</footer>
