@page
@model peeposredemption.API.Pages.WikiModel
@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Game Wiki";
    ViewData["OgTitle"] = "Torvex Game Wiki — Items, Monsters & Elements";
    ViewData["Description"] = "Complete Torvex RPG reference: every item, crafting recipes, monster drop tables, and the 12-element guide.";
}

@section Head {
<style>
.wiki-page { max-width: 1200px; margin: 0 auto; padding: 0 24px 80px; }
.wiki-hero { text-align: center; padding: 60px 24px 40px; }
.wiki-hero h1 { font-size: clamp(28px,5vw,44px); font-weight: 800; color: var(--text-primary); margin-bottom: 10px; }
.wiki-hero p  { color: var(--text-secondary); font-size: 16px; }

.wiki-tabs {
    display: flex; gap: 8px; justify-content: center;
    position: sticky; top: 0; z-index: 10;
    background: var(--bg-dark); padding: 16px 0; margin-bottom: 32px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
}
.wiki-tab { padding: 10px 24px; border-radius: 28px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; transition: 0.2s; background: var(--bg-card); color: var(--text-secondary); }
.wiki-tab:hover  { background: rgba(255,255,255,0.1); color: var(--text-primary); }
.wiki-tab.active { background: var(--accent); color: white; }

.wiki-section { display: none; }
.wiki-section.active { display: block; }

.wiki-controls { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 24px; }
.wiki-search { flex: 1; min-width: 200px; padding: 10px 16px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg-card); color: var(--text-primary); font-size: 14px; }
.wiki-search::placeholder { color: var(--text-muted); }
.wiki-search:focus { outline: none; border-color: var(--accent); }
.filter-btn { padding: 10px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; border: 1px solid rgba(255,255,255,0.1); background: var(--bg-card); color: var(--text-secondary); transition: 0.15s; }
.filter-btn:hover  { border-color: var(--accent); color: var(--text-primary); }
.filter-btn.active { background: var(--accent); color: white; border-color: var(--accent); }

/* Item grid */
.item-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; }
.item-card {
    display: flex; align-items: center; gap: 10px;
    background: var(--bg-card); border-radius: 10px; padding: 12px 14px;
    border: 1px solid rgba(255,255,255,0.06); text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
}
.item-card:hover { border-color: var(--accent); background: rgba(0,191,165,0.06); }
.item-card-icon { font-size: 24px; flex-shrink: 0; }
.item-card-info { overflow: hidden; }
.item-card-name { font-size: 13px; font-weight: 600; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.item-card-sub  { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
.rarity-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; margin-left: auto; }
.dot-Common    { background: #b0b0b0; }
.dot-Uncommon  { background: #3ba55c; }
.dot-Rare      { background: #7289da; }
.dot-Epic      { background: #c678dd; }
.dot-Legendary { background: #ffa500; }

/* Monster grid */
.monster-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 10px; }
.monster-card {
    display: flex; align-items: center; gap: 12px;
    background: var(--bg-card); border-radius: 10px; padding: 12px 14px;
    border: 1px solid rgba(255,255,255,0.06); text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
}
.monster-card:hover { border-color: var(--accent); background: rgba(0,191,165,0.06); }
.monster-icon { font-size: 28px; flex-shrink: 0; }
.monster-card-info { overflow: hidden; flex: 1; }
.monster-name { font-size: 13px; font-weight: 700; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.monster-meta { font-size: 11px; color: var(--text-muted); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.level-badge { font-size: 12px; font-weight: 700; padding: 2px 8px; border-radius: 12px; background: rgba(255,255,255,0.08); color: var(--text-secondary); flex-shrink: 0; }

/* Peepo grid */
.peepo-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 10px; }
.peepo-card { background: var(--bg-card); border-radius: 10px; padding: 12px 8px; border: 1px solid rgba(255,255,255,0.06); text-align: center; }
.peepo-img { width: 56px; height: 56px; object-fit: contain; border-radius: 6px; }
.peepo-name { font-size: 11px; color: var(--text-muted); margin-top: 6px; word-break: break-word; line-height: 1.3; }
.peepo-rarity { font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 8px; margin-top: 4px; display: inline-block; }
.peepo-Common    { background: rgba(180,180,180,0.12); color: #b0b0b0; }
.peepo-Uncommon  { background: rgba(59,165,92,0.15);   color: #3ba55c; }
.peepo-Rare      { background: rgba(88,101,242,0.15);  color: #7289da; }
.peepo-Epic      { background: rgba(163,73,164,0.15);  color: #c678dd; }
.peepo-Legendary { background: rgba(255,165,0,0.15);   color: #ffa500; }
.peepo-pagination { display: flex; gap: 8px; justify-content: center; margin-top: 24px; flex-wrap: wrap; }
.page-btn { padding: 8px 16px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg-card); color: var(--text-secondary); cursor: pointer; font-size: 13px; font-weight: 600; transition: 0.15s; }
.page-btn:hover { border-color: var(--accent); color: var(--text-primary); }
.page-btn.active { background: var(--accent); color: white; border-color: var(--accent); }
.peepo-info { font-size: 13px; color: var(--text-muted); margin-bottom: 16px; }

/* Elements */
.elem-intro { font-size: 14px; color: var(--text-secondary); margin-bottom: 24px; line-height: 1.7; }
.elem-intro strong { color: var(--text-primary); }
.elem-legend { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 32px; }
.legend-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-secondary); }
.legend-swatch { width: 16px; height: 16px; border-radius: 4px; }
.swatch-strong  { background: rgba(59,165,92,0.4); }
.swatch-mutual  { background: rgba(88,101,242,0.4); }
.swatch-resist  { background: rgba(255,80,80,0.3); }
.swatch-neutral { background: rgba(255,255,255,0.1); }
.elem-matrix-wrap { overflow-x: auto; margin-bottom: 40px; }
.elem-matrix { border-collapse: collapse; min-width: 600px; width: 100%; font-size: 13px; }
.elem-matrix th, .elem-matrix td { text-align: center; padding: 8px 6px; border: 1px solid rgba(255,255,255,0.06); }
.elem-matrix th { background: var(--bg-card); color: var(--text-secondary); font-weight: 600; font-size: 12px; }
.elem-matrix td.row-label { text-align: left; padding-left: 12px; font-weight: 600; color: var(--text-primary); background: var(--bg-card); white-space: nowrap; }
.cell-strong  { background: rgba(59,165,92,0.2);  color: #4ade80; font-weight: 700; }
.cell-mutual  { background: rgba(88,101,242,0.2); color: #7289da; font-weight: 700; }
.cell-resist  { background: rgba(255,80,80,0.18); color: #ff6464; font-weight: 700; }
.cell-self    { background: rgba(255,140,0,0.18); color: #ffaa44; font-weight: 700; }
.cell-neutral { color: var(--text-muted); }
.section-title { font-size: 22px; font-weight: 700; color: var(--text-primary); margin-bottom: 20px; }
.status-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; margin-top: 8px; }
.status-card { background: var(--bg-card); border-radius: 10px; padding: 14px; border: 1px solid rgba(255,255,255,0.06); }
.status-card-header { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
.status-effect { font-size: 13px; color: var(--accent); font-weight: 600; }
.status-params { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
.status-table { width: 100%; border-collapse: collapse; font-size: 14px; }
.status-table th { font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; padding: 8px 12px; border-bottom: 1px solid rgba(255,255,255,0.08); text-align: left; }
.status-table td { padding: 10px 12px; border-bottom: 1px solid rgba(255,255,255,0.04); color: var(--text-secondary); vertical-align: middle; }
.status-table tr:last-child td { border-bottom: none; }
.status-table tr:hover td { background: rgba(255,255,255,0.02); }
.status-table td:first-child { font-size: 20px; width: 36px; }

.elem-Fire      { color: #ff7043; } .elem-Ice       { color: #81d4fa; }
.elem-Lightning { color: #ffd54f; } .elem-Earth     { color: #a5d6a7; }
.elem-Water     { color: #4fc3f7; } .elem-Wind      { color: #e0e0e0; }
.elem-Holy      { color: #fff59d; } .elem-Dark      { color: #ce93d8; }
.elem-Light     { color: #fff9c4; } .elem-Shadow    { color: #b39ddb; }
.elem-Poison    { color: #aed581; } .elem-Void      { color: #90a4ae; }

/* Recipes */
.recipe-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; }
.recipe-card {
    background: var(--bg-card); border-radius: 12px; padding: 16px;
    border: 1px solid rgba(255,255,255,0.06);
    transition: border-color 0.15s;
}
.recipe-card:hover { border-color: var(--accent); }
.recipe-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.recipe-icon { font-size: 26px; flex-shrink: 0; }
.recipe-name { font-size: 14px; font-weight: 700; color: var(--text-primary); }
.recipe-skill { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
.recipe-output { font-size: 13px; color: var(--accent); font-weight: 600; margin-bottom: 8px; }
.recipe-ingredients { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }
.recipe-ing { font-size: 12px; background: rgba(255,255,255,0.05); border-radius: 6px; padding: 4px 8px; color: var(--text-secondary); white-space: nowrap; }
.recipe-stats { display: flex; gap: 12px; flex-wrap: wrap; }
.recipe-stat { font-size: 11px; color: var(--text-muted); }
.recipe-stat strong { color: var(--text-secondary); }

.wiki-loading { text-align: center; padding: 60px 0; color: var(--text-muted); font-size: 15px; }

@@media (max-width: 600px) {
    .wiki-tabs { gap: 4px; }
    .wiki-tab  { padding: 8px 14px; font-size: 13px; }
    .item-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); }
    .monster-grid { grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); }
}
</style>
}

<div class="wiki-hero">
    <h1>⚔️ Torvex Game Wiki</h1>
    <p>Items, monsters, crafting recipes, drop tables, and the full element guide.</p>
</div>

<div class="wiki-page">
    <div class="wiki-tabs">
        <button class="wiki-tab active" onclick="showSection('items', this)">📦 Items</button>
        <button class="wiki-tab"        onclick="showSection('monsters', this)">👾 Monsters</button>
        <button class="wiki-tab"        onclick="showSection('recipes', this)">⚒️ Recipes</button>
        <button class="wiki-tab"        onclick="showSection('elements', this)">🔥 Elements</button>
        <button class="wiki-tab"        onclick="showSection('status', this)">💊 Status</button>
        <button class="wiki-tab"        onclick="showSection('peepos', this)">🐸 Peepos</button>
    </div>

    <!-- ══════════════════════════════════════════════════════ ITEMS -->
    <div id="section-items" class="wiki-section active">
        <div class="wiki-controls">
            <input type="text" class="wiki-search" id="item-search" placeholder="Search items…" oninput="filterItems()" />
            <button class="filter-btn active" data-filter="All"          onclick="setItemFilter(this,'All')">All</button>
            <button class="filter-btn"        data-filter="Weapons"      onclick="setItemFilter(this,'Weapons')">Weapons</button>
            <button class="filter-btn"        data-filter="Armor"        onclick="setItemFilter(this,'Armor')">Armor</button>
            <button class="filter-btn"        data-filter="Consumables"  onclick="setItemFilter(this,'Consumables')">Consumables</button>
            <button class="filter-btn"        data-filter="Materials"    onclick="setItemFilter(this,'Materials')">Materials</button>
            <button class="filter-btn"        data-filter="Tools"        onclick="setItemFilter(this,'Tools')">Tools</button>
        </div>
        <div id="item-grid" class="item-grid">
            <div class="wiki-loading">Loading items…</div>
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════ MONSTERS -->
    <div id="section-monsters" class="wiki-section">
        <div class="wiki-controls">
            <input type="text" class="wiki-search" id="monster-search" placeholder="Search monsters…" oninput="filterMonsters()" />
            <div id="zone-filters">
                <button class="filter-btn active" data-zone="All" onclick="setZoneFilter(this,'All')">All Zones</button>
            </div>
        </div>
        <div id="monster-grid" class="monster-grid">
            <div class="wiki-loading">Loading monsters…</div>
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════ RECIPES -->
    <div id="section-recipes" class="wiki-section">
        <div class="wiki-controls">
            <input type="text" class="wiki-search" id="recipe-search" placeholder="Search recipes…" oninput="filterRecipes()" />
            <button class="filter-btn active" data-rskill="All"         onclick="setRecipeSkill(this,'All')">All Skills</button>
            <button class="filter-btn"        data-rskill="Smithing"    onclick="setRecipeSkill(this,'Smithing')">⚒️ Smithing</button>
            <button class="filter-btn"        data-rskill="Woodcutting" onclick="setRecipeSkill(this,'Woodcutting')">🪵 Woodcutting</button>
            <button class="filter-btn"        data-rskill="Cooking"     onclick="setRecipeSkill(this,'Cooking')">🍳 Cooking</button>
        </div>
        <div id="recipe-list" class="recipe-list">
            <div class="wiki-loading">Loading recipes…</div>
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════ PEEPOS -->
    <div id="section-peepos" class="wiki-section">
        <p class="peepo-info">Peepo collectibles drop from monsters and can be traded on the marketplace. Rarity affects drop chance and value.</p>
        <div id="peepo-grid" class="peepo-grid">
            <div class="wiki-loading">Loading peepos…</div>
        </div>
        <div id="peepo-pagination" class="peepo-pagination"></div>
    </div>

    <!-- ══════════════════════════════════════════════════ STATUS EFFECTS -->
    <div id="section-status" class="wiki-section">
        <p class="elem-intro">
            Status effects are applied by monster abilities, elemental hits, or spells.
            Most wear off after a set number of turns — your <strong>LUK</strong> stat gives a chance to shake them off early.
            <strong>Combat-only</strong> effects clear when battle ends.
        </p>

        <div class="section-title" style="margin-top:20px">Debuffs</div>
        <table class="status-table">
            <thead><tr><th>Icon</th><th>Name</th><th>Effect</th><th>Source</th><th>Duration</th></tr></thead>
            <tbody>
                <tr><td>☠️</td><td><strong>Poison</strong></td><td>Deals % of your Max HP each turn</td><td>Poison element · Bio spells</td><td>4 turns</td></tr>
                <tr><td>🔥</td><td><strong>Burn</strong></td><td>Deals flat damage per turn. Stacks up to 3×</td><td>Fire element · Fire spells</td><td>3 turns</td></tr>
                <tr><td>🩸</td><td><strong>Bleed</strong></td><td>Deals flat damage per turn. Stacks up to 3×</td><td>Monster abilities</td><td>Varies</td></tr>
                <tr><td>🧊</td><td><strong>Freeze</strong></td><td>Deals cold damage and <em>skips your turn</em></td><td>Ice element · Blizzard spells</td><td>2 turns</td></tr>
                <tr><td>⚡</td><td><strong>Shock</strong></td><td>Deals lightning damage · 25% chance to stun each tick</td><td>Lightning element · Thunder spells</td><td>2 turns</td></tr>
                <tr><td>🌀</td><td><strong>Corrupt</strong></td><td>Deals void damage per turn</td><td>Void element · Shadow spells</td><td>4 turns</td></tr>
                <tr><td>💧</td><td><strong>MP Drain</strong></td><td>Drains MP each turn</td><td>Water element · Aqua spells</td><td>3 turns</td></tr>
                <tr><td>🛡️↓</td><td><strong>Defense Down</strong></td><td>Reduces your DEF stat</td><td>Earth element · Monster abilities</td><td>3 turns</td></tr>
                <tr><td>⚔️↓</td><td><strong>Attack Down</strong></td><td>Reduces your STR stat</td><td>Monster abilities</td><td>Varies</td></tr>
                <tr><td>👁️</td><td><strong>Blind</strong></td><td>Increases your miss chance on attacks</td><td>Light element · Monster abilities</td><td>3 turns</td></tr>
                <tr><td>💔</td><td><strong>Blight</strong></td><td>Inverts all healing — potions and cure spells <em>deal damage</em> instead</td><td>Dark element · Dark spells</td><td>3 turns</td></tr>
                <tr><td>🌑</td><td><strong>Curse</strong></td><td>Halves the amount healed by all healing spells</td><td>Monster abilities</td><td>Varies</td></tr>
                <tr><td>💫</td><td><strong>Confusion</strong> <span style="font-size:11px;color:var(--text-muted)">(combat only)</span></td><td>50% chance to attack yourself instead of the enemy</td><td>Shadow element · Monster abilities</td><td>3 turns</td></tr>
                <tr><td>🔇</td><td><strong>Silence</strong> <span style="font-size:11px;color:var(--text-muted)">(combat only)</span></td><td>Prevents casting any magic spells</td><td>Monster abilities</td><td>Varies</td></tr>
                <tr><td>🪨</td><td><strong>Stone</strong> <span style="font-size:11px;color:var(--text-muted)">(combat only)</span></td><td>Fully skips your turn — you cannot act at all</td><td>Monster abilities</td><td>Varies</td></tr>
                <tr><td>🌪️</td><td><strong>Windblast</strong> <span style="font-size:11px;color:var(--text-muted)">(combat only)</span></td><td>Blown away — skips your turn</td><td>Wind element · Aero spells</td><td>1 turn</td></tr>
                <tr><td>⏳</td><td><strong>Slow</strong></td><td>Skips every other turn</td><td>Monster abilities</td><td>Varies</td></tr>
            </tbody>
        </table>

        <div class="section-title" style="margin-top:32px">Buffs</div>
        <table class="status-table">
            <thead><tr><th>Icon</th><th>Name</th><th>Effect</th><th>Source</th><th>Duration</th></tr></thead>
            <tbody>
                <tr><td>💚</td><td><strong>Regeneration</strong></td><td>Restores HP each turn</td><td>Holy element · Holy spells</td><td>3 turns</td></tr>
                <tr><td>🪖</td><td><strong>Phys Resist</strong></td><td>Reduces physical damage taken by a %</td><td>Monster innate · Barrier spells</td><td>Varies</td></tr>
                <tr><td>✨</td><td><strong>Magic Resist</strong></td><td>Reduces magic damage taken by a %</td><td>Monster innate</td><td>Varies</td></tr>
            </tbody>
        </table>

        <div class="section-title" style="margin-top:32px">Monster-only</div>
        <table class="status-table">
            <thead><tr><th>Icon</th><th>Name</th><th>Effect</th></tr></thead>
            <tbody>
                <tr><td>😡</td><td><strong>Berserk</strong></td><td>Monster deals significantly increased damage</td></tr>
            </tbody>
        </table>

        <p style="font-size:13px;color:var(--text-muted);margin-top:24px">
            💡 <strong>LUK</strong> gives a <em>LUK × 10%</em> chance (max 80%) to shake off a status effect early each turn.<br>
            Effects marked <strong>combat only</strong> are automatically cleared when you leave battle.
        </p>
    </div>

    <!-- ══════════════════════════════════════════════════ ELEMENTS -->
    <div id="section-elements" class="wiki-section">
        <p class="elem-intro">
            Torvex uses a <strong>12-element system</strong>. Every monster and weapon has an element.
            Attacking with a strong element deals bonus damage — <strong>1.5× for magic spells</strong>, <strong>1.25× for weapon attacks</strong>.
            Attacking into a resistance deals <strong>0.75×</strong>. Same element vs same element is always <strong>0.75×</strong>.
        </p>
        <div class="elem-legend">
            <div class="legend-item"><div class="legend-swatch swatch-strong"></div> Strong (1.5× magic / 1.25× weapon)</div>
            <div class="legend-item"><div class="legend-swatch swatch-mutual"></div> Mutual Strong (both directions)</div>
            <div class="legend-item"><div class="legend-swatch swatch-resist"></div> Resisted (0.75×)</div>
            <div class="legend-item"><div class="legend-swatch swatch-neutral"></div> Neutral (1.0×)</div>
            <div class="legend-item"><div class="legend-swatch" style="background:rgba(255,140,0,0.4)"></div> Same Element (0.5×)</div>
        </div>
        @{
            var elems = new[] { "Fire","Ice","Lightning","Earth","Water","Wind","Holy","Dark","Light","Shadow","Poison","Void" };
            var icons = new[] { "🔥","❄️","⚡","🌍","💧","🌪️","✨","🌑","💡","👤","☠️","🌀" };
            string[,] matrix = new string[12,12];
            for (int a = 0; a < 12; a++)
            for (int d = 0; d < 12; d++)
            {
                if (a == d) { matrix[a,d] = "X"; continue; }
                var (at, dt) = (elems[a], elems[d]);
                bool mutual = (at=="Fire"&&dt=="Earth")||(at=="Earth"&&dt=="Fire")||(at=="Holy"&&dt=="Dark")||(at=="Dark"&&dt=="Holy")||(at=="Holy"&&dt=="Shadow")||(at=="Shadow"&&dt=="Holy")||(at=="Dark"&&dt=="Light")||(at=="Light"&&dt=="Dark")||(at=="Light"&&dt=="Shadow")||(at=="Shadow"&&dt=="Light");
                bool strong = (at=="Fire"&&dt=="Ice")||(at=="Ice"&&dt=="Water")||(at=="Ice"&&dt=="Wind")||(at=="Lightning"&&dt=="Ice")||(at=="Lightning"&&dt=="Water")||(at=="Earth"&&dt=="Lightning")||(at=="Water"&&dt=="Fire")||(at=="Water"&&dt=="Earth")||(at=="Wind"&&dt=="Lightning")||(at=="Wind"&&dt=="Earth")||(at=="Poison"&&dt=="Earth")||(at=="Poison"&&dt=="Water");
                bool resisted = (dt=="Fire"&&at=="Ice")||(dt=="Ice"&&at=="Water")||(dt=="Ice"&&at=="Wind")||(dt=="Lightning"&&at=="Ice")||(dt=="Lightning"&&at=="Water")||(dt=="Earth"&&at=="Lightning")||(dt=="Water"&&at=="Fire")||(dt=="Water"&&at=="Earth")||(dt=="Wind"&&at=="Lightning")||(dt=="Wind"&&at=="Earth")||(dt=="Poison"&&at=="Earth")||(dt=="Poison"&&at=="Water");
                matrix[a,d] = mutual ? "M" : strong ? "S" : resisted ? "R" : ".";
            }
        }
        <div class="elem-matrix-wrap">
        <table class="elem-matrix">
            <thead>
                <tr>
                    <th style="text-align:left;padding-left:12px">Attacker ↓ / Defender →</th>
                    @for (int d = 0; d < 12; d++) { <th title="@elems[d]">@icons[d]</th> }
                </tr>
            </thead>
            <tbody>
                @for (int a = 0; a < 12; a++)
                {
                    <tr>
                        <td class="row-label">@icons[a] @elems[a]</td>
                        @for (int d = 0; d < 12; d++)
                        {
                            var cell = matrix[a,d];
                            var css = cell switch { "S"=>"cell-strong","M"=>"cell-mutual","R"=>"cell-resist","X"=>"cell-self",_=>"cell-neutral" };
                            <td class="@css" title="@elems[a] vs @elems[d]">@(cell=="X"?"½":cell=="."?"·":cell)</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
        </div>
        <div class="section-title">Status Effects on Hit</div>
        <div class="status-grid">
            @{
                var statusData = new[] {
                    ("Fire","🔥","Burn","8 dmg/turn","3 turns"),("Ice","❄️","Freeze","5 dmg/turn","2 turns"),
                    ("Lightning","⚡","Shock","6 dmg/turn","2 turns"),("Earth","🌍","Defense Down","-5 DEF","3 turns"),
                    ("Water","💧","MP Drain","6 MP/turn","3 turns"),("Wind","🌪️","Windblast","Skip turn","1 turn"),
                    ("Holy","✨","Regeneration","+12 HP/turn","3 turns"),("Dark","🌑","Blight","Healing inverted","3 turns"),
                    ("Light","💡","Blind","Miss chance","3 turns"),("Shadow","👤","Confusion","Random target","3 turns"),
                    ("Poison","☠️","Poison","4 dmg/turn","4 turns"),("Void","🌀","Corrupt","5 dmg/turn","4 turns"),
                };
            }
            @foreach (var (name,icon,effect,strength,duration) in statusData)
            {
                <div class="status-card">
                    <div class="status-card-header">
                        <span style="font-size:20px">@icon</span>
                        <span style="font-size:14px;font-weight:700;color:var(--text-primary)" class="elem-@name">@name</span>
                    </div>
                    <div class="status-effect">@effect</div>
                    <div class="status-params">@strength · @duration</div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
let allItems    = null;
let allMonsters = null;
let allRecipes  = null;
let currentItemFilter  = 'All';
let currentZone        = 'All';
let currentRecipeSkill = 'All';

function showSection(name, btn) {
    document.querySelectorAll('.wiki-section').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('.wiki-tab').forEach(t => t.classList.remove('active'));
    document.getElementById('section-' + name).classList.add('active');
    btn.classList.add('active');
    if (name === 'items'    && !allItems)    loadItems();
    if (name === 'monsters' && !allMonsters) loadMonsters();
    if (name === 'recipes'  && !allRecipes)  loadRecipes();
    if (name === 'peepos')                   loadPeepos(currentPeepoPage);
}

// ── Items ──────────────────────────────────────────────────────────────────

async function loadItems() {
    const res  = await fetch('/api/wiki/items');
    allItems   = await res.json();
    renderItems();
}

function itemFilterTag(item) {
    if (item.subType === 'Pickaxe' || item.subType === 'FishingRod' || item.subType === 'Axe') return 'Tools';
    if (item.type === 'Weapon')     return 'Weapons';
    if (item.type === 'Armor')      return 'Armor';
    if (item.type === 'Consumable') return 'Consumables';
    if (item.type === 'Material')   return 'Materials';
    return 'Other';
}

function renderItems() {
    const q      = (document.getElementById('item-search').value || '').toLowerCase();
    const grid   = document.getElementById('item-grid');
    const items  = allItems.filter(i => {
        const tag = itemFilterTag(i);
        return (currentItemFilter === 'All' || tag === currentItemFilter) &&
               (!q || i.name.toLowerCase().includes(q));
    });
    if (!items.length) { grid.innerHTML = '<div class="wiki-loading">No items found.</div>'; return; }
    const PAGE = 60;
    const shown = items.slice(0, PAGE);
    const rest  = items.length - PAGE;
    function cardHtml(i) {
        const sub = i.levelReq > 0 ? `Lv.${i.levelReq} · ${i.subType}` : i.subType;
        return `<a href="/wiki/item/${i.slug}" class="item-card">
            <span class="item-card-icon">${i.icon}</span>
            <div class="item-card-info">
                <div class="item-card-name">${i.name}</div>
                <div class="item-card-sub">${sub}</div>
            </div>
            <span class="rarity-dot dot-${i.rarity}" title="${i.rarity}"></span>
        </a>`;
    }
    grid.innerHTML = shown.map(cardHtml).join('');
    if (rest > 0) {
        const btn = document.createElement('button');
        btn.className = 'filter-btn';
        btn.style.cssText = 'grid-column:1/-1;margin-top:8px;width:100%;padding:12px';
        btn.textContent = `Show ${rest} more…`;
        btn.onclick = () => { grid.innerHTML = items.map(cardHtml).join(''); };
        grid.appendChild(btn);
    }
}

function setItemFilter(btn, filter) {
    currentItemFilter = filter;
    document.querySelectorAll('#section-items .filter-btn').forEach(b => b.classList.toggle('active', b.dataset.filter === filter));
    if (allItems) renderItems();
}

function filterItems() { if (allItems) renderItems(); }

// ── Monsters ───────────────────────────────────────────────────────────────

async function loadMonsters() {
    const res    = await fetch('/api/wiki/monsters');
    allMonsters  = await res.json();
    // Build zone filter buttons
    const zones  = [...new Set(allMonsters.map(m => m.zone))].sort();
    const zf     = document.getElementById('zone-filters');
    zf.innerHTML = `<button class="filter-btn active" data-zone="All" onclick="setZoneFilter(this,'All')">All Zones</button>`
        + zones.map(z => `<button class="filter-btn" data-zone="${z}" onclick="setZoneFilter(this,'${z}')">${z}</button>`).join('');
    renderMonsters();
}

function renderMonsters() {
    const q    = (document.getElementById('monster-search').value || '').toLowerCase();
    const grid = document.getElementById('monster-grid');
    const mons = allMonsters.filter(m =>
        (currentZone === 'All' || m.zone === currentZone) &&
        (!q || m.name.toLowerCase().includes(q))
    );
    if (!mons.length) { grid.innerHTML = '<div class="wiki-loading">No monsters found.</div>'; return; }

    const elemColors = {Fire:'#ff7043',Ice:'#81d4fa',Lightning:'#ffd54f',Earth:'#a5d6a7',Water:'#4fc3f7',
        Wind:'#e0e0e0',Holy:'#fff59d',Dark:'#ce93d8',Light:'#fff9c4',Shadow:'#b39ddb',Poison:'#aed581',Void:'#90a4ae'};

    grid.innerHTML = mons.map(m => {
        const elemColor = elemColors[m.element] || 'var(--text-muted)';
        const elemLabel = m.element === 'None' ? '' : m.element;
        const meta = [m.zone, elemLabel ? `<span style="color:${elemColor}">${elemLabel}</span>` : ''].filter(Boolean).join(' · ');
        return `<a href="/wiki/monster/${m.slug}" class="monster-card">
            <span class="monster-icon">${m.icon}</span>
            <div class="monster-card-info">
                <div class="monster-name">${m.name}</div>
                <div class="monster-meta">${meta}</div>
            </div>
            <span class="level-badge">Lv.${m.level}</span>
        </a>`;
    }).join('');
}

function setZoneFilter(btn, zone) {
    currentZone = zone;
    document.querySelectorAll('#zone-filters .filter-btn').forEach(b => b.classList.toggle('active', b.dataset.zone === zone));
    if (allMonsters) renderMonsters();
}

function filterMonsters() { if (allMonsters) renderMonsters(); }

// ── Recipes ────────────────────────────────────────────────────────────────

async function loadRecipes() {
    const res = await fetch('/api/wiki/recipes');
    allRecipes = await res.json();
    renderRecipes();
}

const skillIcons = { Smithing: '⚒️', Woodcutting: '🪵', Cooking: '🍳', Alchemy: '⚗️' };

function renderRecipes() {
    const q    = (document.getElementById('recipe-search').value || '').toLowerCase();
    const list = document.getElementById('recipe-list');
    const recipes = allRecipes.filter(r =>
        (currentRecipeSkill === 'All' || r.skill === currentRecipeSkill) &&
        (!q || r.name.toLowerCase().includes(q) ||
               r.output.name.toLowerCase().includes(q) ||
               r.ingredients.some(i => i.name.toLowerCase().includes(q)))
    );
    if (!recipes.length) { list.innerHTML = '<div class="wiki-loading">No recipes found.</div>'; return; }

    list.innerHTML = recipes.map(r => {
        const icon = skillIcons[r.skill] || '⚒️';
        const ingHtml = r.ingredients.map(i =>
            `<span class="recipe-ing">${i.icon} ${i.name} ×${i.qty}</span>`
        ).join('');
        const stats = [
            `<span class="recipe-stat">📊 <strong>${r.successRate}%</strong> success</span>`,
            `<span class="recipe-stat">✨ <strong>${r.xpReward.toLocaleString()}</strong> XP</span>`,
            r.orbCost > 0 ? `<span class="recipe-stat">🔮 <strong>${r.orbCost.toLocaleString()}</strong> orbs</span>` : null,
        ].filter(Boolean).join('');
        return `<div class="recipe-card">
            <div class="recipe-header">
                <span class="recipe-icon">${r.output.icon}</span>
                <div>
                    <div class="recipe-name">${r.name}</div>
                    <div class="recipe-skill">${icon} ${r.skill} Lv.${r.skillLevel}</div>
                </div>
            </div>
            <div class="recipe-output">→ ${r.output.qty > 1 ? r.output.qty + '× ' : ''}${r.output.name}</div>
            <div class="recipe-ingredients">${ingHtml}</div>
            <div class="recipe-stats">${stats}</div>
        </div>`;
    }).join('');
}

function setRecipeSkill(btn, skill) {
    currentRecipeSkill = skill;
    document.querySelectorAll('#section-recipes .filter-btn').forEach(b => b.classList.toggle('active', b.dataset.rskill === skill));
    if (allRecipes) renderRecipes();
}

function filterRecipes() { if (allRecipes) renderRecipes(); }

// ── Peepos ─────────────────────────────────────────────────────────────────

let currentPeepoPage = 1;
let peepoTotal = 0;
let peepoPageSize = 60;

async function loadPeepos(page) {
    currentPeepoPage = page;
    document.getElementById('peepo-grid').innerHTML = '<div class="wiki-loading">Loading peepos…</div>';
    const res  = await fetch(`/api/wiki/collectibles?page=${page}`);
    const data = await res.json();
    peepoTotal    = data.total;
    peepoPageSize = data.pageSize;

    const grid = document.getElementById('peepo-grid');
    grid.innerHTML = data.items.map(p => {
        const isUrl = p.icon.startsWith('http');
        const iconHtml = isUrl
            ? `<img class="peepo-img" src="${p.icon}" alt="${p.name}" loading="lazy">`
            : `<div style="font-size:48px;line-height:1">${p.icon}</div>`;
        const priceHtml = p.sellPrice > 0 ? `<div style="font-size:10px;color:var(--text-muted);margin-top:2px">🪙 ${p.sellPrice.toLocaleString()}</div>` : '';
        return `<div class="peepo-card">
            ${iconHtml}
            <div class="peepo-name">${p.name}</div>
            <span class="peepo-rarity peepo-${p.rarity}">${p.rarity}</span>
            ${priceHtml}
        </div>`;
    }).join('');

    // Pagination
    const totalPages = Math.ceil(peepoTotal / peepoPageSize);
    const pag = document.getElementById('peepo-pagination');
    if (totalPages <= 1) { pag.innerHTML = ''; return; }
    let html = '';
    if (page > 1) html += `<button class="page-btn" onclick="loadPeepos(${page-1})">← Prev</button>`;
    for (let p = Math.max(1, page-2); p <= Math.min(totalPages, page+2); p++) {
        html += `<button class="page-btn${p===page?' active':''}" onclick="loadPeepos(${p})">${p}</button>`;
    }
    if (page < totalPages) html += `<button class="page-btn" onclick="loadPeepos(${page+1})">Next →</button>`;
    html += `<span style="font-size:13px;color:var(--text-muted);align-self:center">${peepoTotal} total</span>`;
    pag.innerHTML = html;
}

// Load items on initial page load (items tab is active by default)
loadItems();
</script>
}
